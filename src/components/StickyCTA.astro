---
---

<div
  class="fixed bottom-4 right-4 z-40 md:hidden"
  x-data="{ visible: false, dismissed: false }"
  x-init="setTimeout(() => visible = true, 1800)"
  x-show="visible && !dismissed"
  x-transition:enter="transition duration-500 ease-out"
  x-transition:enter-start="translate-y-4 opacity-0"
  x-transition:enter-end="translate-y-0 opacity-100"
  x-cloak
>
  <div class="relative">
    <button
      type="button"
      x-on:click="dismissed = true"
      class="absolute -right-1 -top-1 z-10 flex h-5 w-5 items-center justify-center rounded-full border border-ink/20 bg-paper text-ink shadow-sm"
      aria-label="Cerrar"
    >
      <svg class="h-2.5 w-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round">
        <path d="M6 6l12 12M6 18L18 6"/>
      </svg>
    </button>
    <a
      href="https://play.google.com/store/apps/details?id=com.bookverse.contacts"
      target="_blank"
      rel="noopener"
      class="group flex h-14 w-14 items-center justify-center rounded-full bg-ink text-paper shadow-2xl transition-all hover:scale-105 hover:bg-flame"
      aria-label="Instalar Fun Phone"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
        <path d="M5 4l14 8-14 8V4z"/>
      </svg>
      <span class="absolute -left-2 -top-1 flex h-5 w-5 items-center justify-center rounded-full bg-flame text-[0.6rem] font-extrabold text-paper">
        ★
      </span>
    </a>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[x-data*="dismissed"]');
    if (!root) return;
    window.addEventListener('lang', () => {
      // Re-render is automatic; the static aria-label is good for both languages
    });
  })();
</script>
