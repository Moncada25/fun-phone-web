---
const baseUrl = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const sections = [
  {
    title: { es: 'Producto', en: 'Product' },
    items: [
      { es: 'Funciones', en: 'Features', href: baseUrl + 'features/' },
      { es: 'Hoja de ruta', en: 'Roadmap', href: baseUrl + 'roadmap/' },
      { es: 'Preguntas frecuentes', en: 'FAQ', href: baseUrl + 'faq/' },
      { es: 'Código fuente', en: 'Source code', href: 'https://github.com/Moncada25/fun-phone', external: true },
    ]
  },
  {
    title: { es: 'Legal', en: 'Legal' },
    items: [
      { es: 'Privacidad', en: 'Privacy', href: baseUrl + 'privacy/' },
      { es: 'Google Play', en: 'Google Play', href: 'https://play.google.com/store/apps/details?id=com.bookverse.contacts', external: true },
      { es: 'Licencia GPL v3', en: 'GPL v3 License', href: 'https://github.com/Moncada25/fun-phone/blob/main/LICENSE', external: true },
    ]
  },
  {
    title: { es: 'Contacto', en: 'Contact' },
    items: [
      { es: 'santiago.moncada.dev@gmail.com', en: 'santiago.moncada.dev@gmail.com', href: 'mailto:santiago.moncada.dev@gmail.com', mono: true },
      { es: '+57 301 249 9315', en: '+57 301 249 9315', href: 'tel:+573012499315', mono: true },
      { es: 'Medellín, Colombia', en: 'Medellín, Colombia', href: null },
    ]
  }
];
---

<footer class="relative mt-24 border-t border-ink/15 bg-paper">
  <!-- Top marquee -->
  <div class="overflow-hidden border-b border-ink/15 py-6">
    <div class="marquee-track">
      {Array.from({ length: 8 }).map(() => (
        <div class="flex shrink-0 items-center gap-8 pr-8 font-display text-[2.5rem] font-extrabold leading-none tracking-tighter md:text-[4rem]">
          <span class="text-ink">Fun Phone</span>
          <span class="text-flame">★</span>
          <span class="font-serif-italic text-flame">on-device</span>
          <span class="text-ink">·</span>
          <span class="text-ink">sin servidores</span>
          <span class="text-flame">★</span>
          <span class="font-serif-italic text-ink">zero ads</span>
          <span class="text-ink">·</span>
          <span class="text-ink">cero BS</span>
          <span class="text-flame">★</span>
        </div>
      ))}
    </div>
  </div>

  <div class="container-editorial py-16 md:py-20">
    <!-- Masthead row -->
      <div class="grid gap-12 border-b border-ink/15 pb-12 lg:grid-cols-[1.5fr_1fr]">
        <div>
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">
            <span x-show="lang==='es'">Fun Phone · The Codeword</span>
            <span x-show="lang==='en'">Fun Phone · The Codeword</span>
          </p>
          <h2 class="mt-4 max-w-xl text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.92] tracking-tightest md:text-[3.5rem]">
            <span class="text-ink">
              <span x-show="lang==='es'">Una app de teléfono </span>
              <span x-show="lang==='en'">A phone app </span>
            </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">hecha a mano</span>
              <span x-show="lang==='en'">hand-crafted</span>
            </span>
            <span class="text-ink">
              <span x-show="lang==='es'"> y open source.</span>
              <span x-show="lang==='en'"> and open source.</span>
            </span>
          </h2>
          <p class="mt-6 max-w-md text-pretty text-sm text-ink-muted md:text-base">
            <span x-show="lang==='es'">Construida en Medellín · Distribuida en el mundo. GPL v3, sin telemetría oculta, sin patrones oscuros, sin servidores obligatorios.</span>
            <span x-show="lang==='en'">Built in Medellín · Distributed globally. GPL v3, no hidden telemetry, no dark patterns, no mandatory servers.</span>
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" class="btn-primary group">
              <span x-show="lang==='es'">Instalar en Google Play</span>
              <span x-show="lang==='en'">Get it on Google Play</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor"><path d="M5 4l14 8-14 8V4z"/></svg>
            </a>
            <a href="https://github.com/Moncada25/fun-phone" target="_blank" rel="noopener" class="btn-ghost group">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.6 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.8-1.6 8.2-6.1 8.2-11.4C24 5.9 18.6.5 12 .5z"/></svg>
              <span>GitHub</span>
              <span class="font-mono text-xs">★</span>
            </a>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-6 self-end">
          <div class="border-l border-ink/15 pl-5">
            <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">v3.16.1</p>
            <p class="mt-1 font-display-condensed text-3xl font-extrabold tracking-tighter text-ink">2026</p>
            <p class="mt-1 text-xs text-ink-ghost">
              <span x-show="lang==='es'">Última edición</span>
              <span x-show="lang==='en'">Latest edition</span>
            </p>
          </div>
          <div class="border-l border-ink/15 pl-5">
            <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">
              <span x-show="lang==='es'">Datos</span>
              <span x-show="lang==='en'">Data</span>
            </p>
            <p class="mt-1 font-display-condensed text-3xl font-extrabold tracking-tighter text-flame">0 KB</p>
            <p class="mt-1 text-xs text-ink-ghost">
              <span x-show="lang==='es'">Compartidos con terceros</span>
              <span x-show="lang==='en'">Shared with third parties</span>
            </p>
          </div>
        </div>
      </div>

    <!-- Columns -->
    <div class="grid gap-10 py-12 sm:grid-cols-2 md:grid-cols-4">
      {sections.map((col) => (
        <div>
          <h3 class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">
            <span x-show={`lang==='es'`}>{col.title.es}</span>
            <span x-show={`lang==='en'`}>{col.title.en}</span>
          </h3>
          <ul class="mt-5 space-y-3">
            {col.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  target={item.external ? '_blank' : undefined}
                  rel={item.external ? 'noopener' : undefined}
                  class:list={[
                    'group inline-flex items-center gap-1.5 transition-colors hover:text-flame',
                    item.mono ? 'font-mono text-xs text-ink-muted' : 'text-sm font-semibold text-ink'
                  ]}
                >
                  <span x-show={`lang==='es'`}>{item.es}</span>
                  <span x-show={`lang==='en'`}>{item.en}</span>
                  {item.external && (
                    <svg class="h-3 w-3 opacity-50 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M7 7h10v10"/>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Logo column -->
      <div>
        <h3 class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">
          <span x-show="lang==='es'">Edición</span>
          <span x-show="lang==='en'">Edition</span>
        </h3>
        <div class="mt-5 flex items-start gap-3">
          <div class="relative flex h-14 w-14 shrink-0 items-center justify-center border border-ink">
            <img src={baseUrl + 'assets/logo.png'} width={40} height={40} alt="Fun Phone" class="h-10 w-10 object-contain" loading="lazy" />
          </div>
          <div>
            <p class="font-display text-sm font-extrabold text-ink">Fun Phone</p>
            <p class="mt-0.5 font-mono text-[0.65rem] uppercase tracking-wider text-ink-ghost">v3.16.1 · build 225</p>
          </div>
        </div>
        <p class="mt-4 text-xs text-ink-muted">
          <span x-show="lang==='es'">Por Bookverse · Colombia</span>
          <span x-show="lang==='en'">By Bookverse · Colombia</span>
        </p>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col items-start justify-between gap-4 border-t border-ink/15 pt-8 md:flex-row md:items-center">
      <p class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-ghost">
        © {year} Fun Phone · Bookverse · <span x-show="lang==='es'">Hecho con cuidado</span><span x-show="lang==='en'">Made with care</span>
      </p>
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1.5 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-ghost">
          <span class="blink-dot inline-block h-1.5 w-1.5 rounded-full bg-flame"></span>
          <span x-show="lang==='es'">Sistema 100% local</span>
          <span x-show="lang==='en'">100% local system</span>
        </span>
        <span class="h-3 w-px bg-ink/15"></span>
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-ghost">ES / EN</span>
      </div>
    </div>
  </div>
</footer>
