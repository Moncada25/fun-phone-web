---
const basePath = import.meta.env.BASE_URL + 'assets/screenshots/';
const v = '?v=4.0.0';

const screenshots = [
  { src: `${basePath}favorites.png${v}`, alt: 'Fun Phone Favorites', caption: { es: 'Favoritos · Conexiones que importan', en: 'Favorites · The connections that matter' }, col: { es: 'Pantalla principal', en: 'Main screen' }, num: '01' },
  { src: `${basePath}tools1.png${v}`, alt: 'Fun Phone Tools Hub', caption: { es: 'Centro de herramientas · 15 utilidades en uno', en: 'Tools hub · 15 utilities in one' }, col: { es: 'Hub', en: 'Hub' }, num: '02' },
  { src: `${basePath}tools2.png${v}`, alt: 'Fun Phone Password Manager', caption: { es: 'Vault · Cifrado Tink + biometría', en: 'Vault · Tink encryption + biometrics' }, col: { es: 'Seguridad', en: 'Security' }, num: '03' },
  { src: `${basePath}tools3.png${v}`, alt: 'Fun Phone Cycle Tracker', caption: { es: 'Calendario menstrual · Predicciones privadas', en: 'Cycle tracker · Private predictions' }, col: { es: 'Bienestar', en: 'Wellness' }, num: '04' },
  { src: `${basePath}dark_mode.png${v}`, alt: 'Fun Phone Dark Mode', caption: { es: 'Personalización · Modo oscuro y acentos', en: 'Personalization · Dark mode & accents' }, col: { es: 'Tema', en: 'Theme' }, num: '05' },
  { src: `${basePath}games.png${v}`, alt: 'Fun Phone Games', caption: { es: '10 juegos · Snake, 2048, Sudoku…', en: '10 games · Snake, 2048, Sudoku…' }, col: { es: 'Juegos', en: 'Games' }, num: '06' },
  { src: `${basePath}notes.png${v}`, alt: 'Fun Phone Notes', caption: { es: 'Notas · Recordatorios y checklists', en: 'Notes · Reminders & checklists' }, col: { es: 'Productividad', en: 'Productivity' }, num: '07' },
  { src: `${basePath}details.png${v}`, alt: 'Fun Phone Contact Details', caption: { es: 'Detalle de contacto · Completo y editable', en: 'Contact detail · Complete & editable' }, col: { es: 'Contactos', en: 'Contacts' }, num: '08' },
];

const carouselData = JSON.stringify(screenshots);
---

<section
  class="relative"
  x-data={`gallery(${carouselData})`}
  x-init="init()"
>
  <!-- Editorial header strip -->
  <div class="mb-8 flex items-end justify-between border-b border-ink/15 pb-4">
    <div>
      <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">
        <span x-show="lang==='es'">Selección · Capítulo 03</span>
        <span x-show="lang==='en'">Selection · Chapter 03</span>
      </p>
      <h3 class="mt-1.5 font-display-condensed text-2xl font-extrabold tracking-tighter md:text-3xl">
        <span x-show="lang==='es'">Una vuelta por la app</span>
        <span x-show="lang==='en'">A walk through the app</span>
      </h3>
    </div>
    <div class="hidden items-center gap-2 sm:flex">
      <button type="button" x-on:click="prev()" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink/15 text-ink-muted transition hover:border-ink hover:text-ink" aria-label="Anterior">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <span class="font-mono text-xs font-bold text-ink-ghost">
        <span x-text="String(currentIndex + 1).padStart(2, '0')"></span>
        <span class="text-ink-ghost/50"> / </span>
        <span x-text="String(screens.length).padStart(2, '0')"></span>
      </span>
      <button type="button" x-on:click="nxt()" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink/15 text-ink-muted transition hover:border-ink hover:text-ink" aria-label="Siguiente">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>
  </div>

  <!-- Stage -->
  <div class="relative">
    <div class="grid gap-6 md:grid-cols-[1fr_1.3fr] md:items-center">
      <!-- Caption column -->
      <div class="order-2 md:order-1">
        <div class="space-y-6">
          <div>
            <span class="inline-flex items-center gap-2 font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">
              <span x-text="screens[currentIndex].num"></span>
              <span class="h-px w-6 bg-flame"></span>
              <span x-show="lang==='es'" x-text="screens[currentIndex].col.es"></span>
              <span x-show="lang==='en'" x-text="screens[currentIndex].col.en"></span>
            </span>
            <p class="mt-4 max-w-md text-balance font-display-condensed text-2xl font-bold leading-tight tracking-tight md:text-3xl">
              <span x-show="lang==='es'" x-text="screens[currentIndex].caption.es"></span>
              <span x-show="lang==='en'" x-text="screens[currentIndex].caption.en"></span>
            </p>
          </div>

          <!-- Thumbs strip -->
          <div class="flex flex-wrap gap-2">
            <template x-for="(s, i) in screens" :key="i">
              <button
                type="button"
                x-on:click="scrollTo(i)"
                class="h-12 w-9 overflow-hidden border transition-all"
                :class="currentIndex === i ? 'border-flame ring-2 ring-flame/30' : 'border-ink/15 opacity-60 hover:opacity-100'"
                :aria-label="`Screenshot ${i + 1}`"
              >
                <img :src="s.src" :alt="s.alt" class="h-full w-full object-cover" loading="lazy" />
              </button>
            </template>
          </div>

          <button
            type="button"
            x-on:click="openLightbox()"
            class="inline-flex items-center gap-1.5 font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-ink underline underline-offset-4 hover:text-flame"
          >
            <span x-show="lang==='es'">Ver en grande</span>
            <span x-show="lang==='en'">View fullscreen</span>
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 3h7v7M21 3l-9 9M10 21H3v-7M3 21l9-9"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Featured image -->
      <div class="order-1 md:order-2">
        <button
          type="button"
          x-on:click="openLightbox()"
          class="group relative block w-full overflow-hidden border border-ink/15 bg-paper-soft"
          style="border-radius: 28px; box-shadow: 0 30px 60px -30px rgba(10,10,10,0.25);"
        >
          <div class="absolute left-5 top-5 z-10 inline-flex items-center gap-2 rounded-full border border-ink/15 bg-paper/90 px-2.5 py-1 font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-muted backdrop-blur">
            <span class="blink-dot inline-block h-1.5 w-1.5 rounded-full bg-flame"></span>
            <span x-show="lang==='es'">En vivo</span>
            <span x-show="lang==='en'">Live</span>
          </div>
          <div class="relative aspect-[9/16] w-full md:aspect-[4/5]">
            <img
              :src="screens[currentIndex].src"
              :alt="screens[currentIndex].alt"
              class="absolute inset-0 h-full w-full object-contain transition-transform duration-700 group-hover:scale-[1.02]"
              loading="lazy"
            />
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div
    x-show="lightbox"
    x-cloak
    x-transition.opacity
    class="fixed inset-0 z-[60] flex items-center justify-center bg-ink/95 p-4 backdrop-blur-sm"
    x-on:click.self="closeLightbox()"
    @keydown.escape.window="lightbox && closeLightbox()"
    @keydown.right.window="lightbox && nxt()"
    @keydown.left.window="lightbox && prev()"
  >
    <button type="button" x-on:click="closeLightbox()" class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full border border-paper/20 bg-paper/5 text-paper transition hover:bg-paper/10" aria-label="Cerrar">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M6 18L18 6"/></svg>
    </button>
    <button type="button" x-on:click="prev()" class="absolute left-4 top-1/2 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-paper/20 bg-paper/5 text-paper transition hover:bg-paper/10 sm:flex" aria-label="Anterior">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button type="button" x-on:click="nxt()" class="absolute right-4 top-1/2 z-10 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-paper/20 bg-paper/5 text-paper transition hover:bg-paper/10 sm:flex" aria-label="Siguiente">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
    </button>
    <figure class="max-h-[88vh] max-w-[92vw]">
      <img :src="screens[currentIndex].src" :alt="screens[currentIndex].alt" class="max-h-[80vh] w-auto rounded-2xl object-contain" />
      <figcaption class="mt-3 text-center font-mono text-xs uppercase tracking-[0.18em] text-paper/70">
        <span class="text-flame" x-text="screens[currentIndex].num"></span>
        · <span x-text="screens[currentIndex].col[lang]"></span>
        · <span x-text="screens[currentIndex].caption[lang]"></span>
      </figcaption>
    </figure>
  </div>
</section>

<script is:inline>
  function gallery(screens) {
    return {
      screens,
      currentIndex: 0,
      lightbox: false,
      tx: null,
      init() {},
      scrollTo(i) { this.currentIndex = i; },
      nxt() { this.currentIndex = (this.currentIndex + 1) % this.screens.length; },
      prev() { this.currentIndex = (this.currentIndex - 1 + this.screens.length) % this.screens.length; },
      openLightbox() { this.lightbox = true; document.documentElement.style.overflow = 'hidden'; },
      closeLightbox() { this.lightbox = false; document.documentElement.style.overflow = ''; },
    };
  }
</script>
