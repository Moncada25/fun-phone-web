---
const basePath = import.meta.env.BASE_URL + 'assets/screenshots/';
const v = '?v=4.0.0';

const screenshots = [
  { src: `${basePath}favorites.png${v}`, alt: 'Fun Phone Favorites', labelEs: 'Conecta con las personas que m\u00e1s importan', labelEn: 'Connect with the people who matter most' },
  { src: `${basePath}tools1.png${v}`, alt: 'Fun Phone Tools Hub', labelEs: 'Centro todo-en-uno de herramientas', labelEn: 'All-in-one tools hub' },
  { src: `${basePath}tools2.png${v}`, alt: 'Fun Phone Password Manager', labelEs: 'Genera y protege claves localmente', labelEn: 'Generate and protect keys locally' },
  { src: `${basePath}tools3.png${v}`, alt: 'Fun Phone Cycle Tracker', labelEs: 'Predicciones de ciclo y bienestar', labelEn: 'Cycle predictions and wellness' },
  { src: `${basePath}dark_mode.png${v}`, alt: 'Fun Phone Dark Mode', labelEs: 'Personaliza cada detalle visual', labelEn: 'Personalize every visual detail' },
  { src: `${basePath}games.png${v}`, alt: 'Fun Phone Games', labelEs: 'Juegos cl\u00e1sicos para cada momento', labelEn: 'Classic games for every moment' },
  { src: `${basePath}notes.png${v}`, alt: 'Fun Phone Notes', labelEs: 'Captura ideas y recordatorios', labelEn: 'Capture ideas and reminders' },
  { src: `${basePath}details.png${v}`, alt: 'Fun Phone Contact Details', labelEs: 'Detalles de contacto completos', labelEn: 'Complete contact details' },
];

const carouselData = JSON.stringify(screenshots);
---
<div
  class="relative"
  x-data={`carousel(${carouselData})`}
  x-init="init()"
  role="region"
  aria-roledescription="carousel"
  aria-label="App screenshots"
>
  <div class="relative overflow-hidden">
    <div
      class="flex gap-4 overflow-x-auto scroll-smooth pb-4 snap-x snap-mandatory scrollbar-hide"
      x-ref="track"
      @mouseenter="stopAuto()"
      @mouseleave="startAuto()"
      @touchstart.passive="tx=$event.changedTouches[0].clientX"
      @touchend.passive="handleSwipe($event)"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >
      {screenshots.map((shot, i) => (
        <button
          type="button"
          class="group relative flex-shrink-0 snap-center cursor-pointer"
          data-idx={i}
          @click="openLightbox(Number($el.dataset.idx))"
        >
          <div class="relative overflow-hidden rounded-2xl border border-neutral-200/60 bg-gradient-to-b from-neutral-50 to-neutral-100 shadow-lg transition-all duration-500 hover:shadow-2xl hover:shadow-accent/10 dark:border-white/10 dark:from-neutral-800 dark:to-neutral-900">
            <img
              src={shot.src}
              alt={shot.alt}
              class="h-[380px] w-auto object-contain transition-transform duration-700 group-hover:scale-[1.02] sm:h-[440px]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <div class="absolute bottom-0 left-0 right-0 translate-y-4 p-4 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              <p class="text-center text-xs font-semibold text-white drop-shadow-lg" x-show="lang==='es'">{shot.labelEs}</p>
              <p class="text-center text-xs font-semibold text-white drop-shadow-lg" x-show="lang==='en'">{shot.labelEn}</p>
            </div>
          </div>
        </button>
      ))}
    </div>
  </div>

  <div class="mt-6 flex items-center justify-center gap-3">
    <button type="button" @click="prev()" class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-200/60 bg-white/80 text-neutral-600 shadow-sm backdrop-blur transition hover:border-accent/30 hover:text-accent dark:border-white/10 dark:bg-neutral-800/80 dark:text-neutral-300" aria-label="Previous">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <div class="flex gap-1.5">
      {screenshots.map((_, i) => (
        <button
          type="button"
          class="h-2 rounded-full transition-all duration-300"
          data-dot={i}
          :class={`currentIndex===${i} ? 'w-6 bg-accent' : 'w-2 bg-neutral-300 dark:bg-neutral-600 hover:bg-accent/50'`}
          @click={`scrollTo(${i})`}
          aria-label={`Screenshot ${i + 1}`}
        ></button>
      ))}
    </div>
    <button type="button" @click="nxt()" class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-200/60 bg-white/80 text-neutral-600 shadow-sm backdrop-blur transition hover:border-accent/30 hover:text-accent dark:border-white/10 dark:bg-neutral-800/80 dark:text-neutral-300" aria-label="Next">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <div x-show="lightbox" x-transition.opacity class="fixed inset-0 z-[60] flex items-center justify-center bg-black/90 p-4 backdrop-blur-sm" @click.self="closeLightbox()" @keydown.escape.window="closeLightbox()" @keydown.right.window="lightbox && nxt()" @keydown.left.window="lightbox && prev()" x-cloak>
    <button type="button" @click="closeLightbox()" class="absolute right-4 top-4 z-10 rounded-full bg-white/10 p-3 text-white transition hover:bg-white/20" aria-label="Close">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button type="button" @click="prev()" class="absolute left-4 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition hover:bg-white/20" aria-label="Previous">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <div class="max-h-[85vh] max-w-[90vw]">
      <img :src="screens[currentIndex].src" :alt="screens[currentIndex].alt" class="max-h-[80vh] w-auto rounded-2xl object-contain shadow-2xl" />
      <p class="mt-3 text-center text-sm font-semibold text-white/90">
        <span x-show="lang==='es'" x-text="screens[currentIndex].labelEs"></span>
        <span x-show="lang==='en'" x-text="screens[currentIndex].labelEn"></span>
      </p>
    </div>
    <button type="button" @click="nxt()" class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition hover:bg-white/20" aria-label="Next">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>
</div>

<script is:inline>
function carousel(screens) {
  return {
    screens,
    currentIndex: 0,
    lightbox: false,
    timer: null,
    tx: null,
    init() { this.startAuto(); },
    startAuto() { if (this.timer) return; this.timer = setInterval(() => this.nxt(), 4000); },
    stopAuto() { clearInterval(this.timer); this.timer = null; },
    scrollTo(i) { this.currentIndex = i; const t = this.$refs.track; const el = t && t.children[i]; if (!el) return; const left = el.offsetLeft - (t.offsetWidth / 2) + (el.offsetWidth / 2); t.scrollTo({ left, behavior: 'smooth' }); },
    nxt() { this.scrollTo((this.currentIndex + 1) % this.screens.length); },
    prev() { this.scrollTo((this.currentIndex - 1 + this.screens.length) % this.screens.length); },
    openLightbox(i) { this.currentIndex = i; this.lightbox = true; this.stopAuto(); document.documentElement.style.overflow = 'hidden'; },
    closeLightbox() { this.lightbox = false; this.startAuto(); document.documentElement.style.overflow = ''; },
    handleSwipe(e) { if (this.tx === null) return; const dx = e.changedTouches[0].clientX - this.tx; if (Math.abs(dx) > 40) dx < 0 ? this.nxt() : this.prev(); this.tx = null; }
  };
}
</script>
