---
const groups = [
  {
    title: { es: 'Teléfono y llamadas', en: 'Phone & calls' },
    description: { es: 'Requerido solo si la app se establece como predeterminada.', en: 'Required only when set as default dialer.' },
    perms: [
      { name: 'CALL_PHONE', purpose: { es: 'Realizar llamadas', en: 'Place calls' } },
      { name: 'ANSWER_PHONE_CALLS', purpose: { es: 'Contestar llamadas', en: 'Answer calls' } },
      { name: 'READ_CALL_LOG', purpose: { es: 'Leer historial', en: 'Read call history' } },
      { name: 'WRITE_CALL_LOG', purpose: { es: 'Escribir historial', en: 'Write call history' } },
    ]
  },
  {
    title: { es: 'Contactos y agenda', en: 'Contacts & address book' },
    description: { es: 'Para gestión local. Nunca salen del dispositivo.', en: 'For local management. Never leave the device.' },
    perms: [
      { name: 'READ_CONTACTS', purpose: { es: 'Mostrar contactos', en: 'Display contacts' } },
      { name: 'WRITE_CONTACTS', purpose: { es: 'Crear/editar contactos', en: 'Create/edit contacts' } },
      { name: 'GET_ACCOUNTS', purpose: { es: 'Sync multi-cuenta', en: 'Multi-account sync' } },
    ]
  },
  {
    title: { es: 'Extras opcionales', en: 'Optional extras' },
    description: { es: 'Solo se piden al usar la función. Siempre revocables.', en: 'Only requested on use. Always revocable.' },
    perms: [
      { name: 'CAMERA', purpose: { es: 'QR y fotos de perfil', en: 'QR & profile photos' } },
      { name: 'RECORD_AUDIO', purpose: { es: 'Notas de voz y dictado', en: 'Voice notes & dictation' } },
      { name: 'READ_CALENDAR', purpose: { es: 'Festivos y eventos', en: 'Holidays & events' } },
    ]
  }
];
---

<div class="space-y-3">
  {groups.map((group, idx) => (
    <details
      class:list={['group relative overflow-hidden border border-ink/15 bg-paper transition-all duration-300 open:border-ink', idx === 0 ? 'open' : '']}
      style="border-radius: 16px;"
    >
      <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 select-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-flame focus-visible:ring-offset-2 focus-visible:ring-offset-paper">
        <div class="flex items-center gap-4">
          <span class="font-mono text-[0.65rem] font-bold text-ink-ghost">{(idx + 1).toString().padStart(2, '0')}</span>
          <div>
            <p class="text-sm font-semibold text-ink">
              <span x-cloak x-show="lang==='es'">{group.title.es}</span>
              <span x-cloak x-show="lang==='en'">{group.title.en}</span>
            </p>
            <p class="mt-0.5 text-xs text-ink-ghost">
              <span x-cloak x-show="lang==='es'">{group.description.es}</span>
              <span x-cloak x-show="lang==='en'">{group.description.en}</span>
            </p>
          </div>
        </div>
        <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border border-ink/15 text-ink-muted transition-transform duration-300 group-open:rotate-180 group-open:border-flame group-open:bg-flame group-open:text-paper">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </span>
      </summary>
      <div class="border-t border-ink/10">
        <ul class="divide-y divide-ink/5">
          {group.perms.map((perm) => (
            <li class="grid grid-cols-[1fr_auto] items-center gap-3 px-5 py-3 text-sm">
              <code class="font-mono text-xs font-medium text-ink">{perm.name}</code>
              <span class="text-xs text-ink-muted">
                <span x-cloak x-show="lang==='es'">{perm.purpose.es}</span>
                <span x-cloak x-show="lang==='en'">{perm.purpose.en}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    </details>
  ))}
</div>
