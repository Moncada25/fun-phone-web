---
export interface Props {
  title: string;
  titleEn?: string;
  bullets: string[];
  bulletsEn?: string[];
}
const { title, titleEn = title, bullets, bulletsEn = bullets } = Astro.props;
---
<div class="group relative overflow-hidden rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur transition-all duration-500 hover:-translate-y-1 hover:border-accent/20 hover:shadow-xl hover:shadow-accent/5 dark:border-white/[0.06] dark:bg-white/[0.02] dark:hover:border-accent/20 dark:hover:shadow-accent/10">
  <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-accent/5 transition-transform duration-700 group-hover:scale-150 dark:bg-accent/10"></div>
  <div class="relative">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div>
        <h3 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
          <span x-show="lang==='es'">{title}</span>
          <span x-show="lang==='en'">{titleEn}</span>
        </h3>
        <div class="mt-1.5 h-0.5 w-8 rounded-full bg-gradient-to-r from-accent to-electric transition-all duration-500 group-hover:w-16"></div>
      </div>
      <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent transition-colors duration-300 group-hover:bg-accent group-hover:text-white dark:bg-accent/20">
        <slot name="icon" />
      </div>
    </div>
    <ul class="space-y-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
      {bullets.map((b, i) => (
        <li class="flex items-start gap-2.5">
          <span class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-accent/60"></span>
          <span>
            <span x-show="lang==='es'">{b}</span>
            <span x-show="lang==='en'">{bulletsEn[i] ?? b}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</div>
