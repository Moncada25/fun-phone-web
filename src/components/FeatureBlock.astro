---
export interface Props {
  title: string;
  titleEn?: string;
  bullets: string[];
  bulletsEn?: string[];
  number?: string;
  variant?: 'light' | 'dark' | 'flame';
  category?: { es: string; en: string };
}

const { title, titleEn = title, bullets, bulletsEn = bullets, number, variant = 'light', category } = Astro.props;
---

<article
  class:list={[
    'group relative flex h-full flex-col overflow-hidden border transition-all duration-500',
    variant === 'dark' && 'border-ink bg-ink text-paper',
    variant === 'flame' && 'border-flame bg-flame text-paper',
    variant === 'light' && 'border-ink/15 bg-paper hover:border-ink',
  ]}
  style="border-radius: 20px;"
>
  <!-- Top meta strip -->
  <header
    class:list={[
      'flex items-center justify-between border-b px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em]',
      variant === 'dark' && 'border-paper/15 text-paper/70',
      variant === 'flame' && 'border-paper/20 text-paper/80',
      variant === 'light' && 'border-ink/10 text-ink-ghost',
    ]}
  >
    <span class="flex items-center gap-2">
      {number && <span x-cloak x-show={variant === 'light' ? "true" : "false"} class="text-flame">{number}</span>}
      {number && <span class:list={[variant === 'dark' && 'text-flame', variant === 'flame' && 'text-paper']}>{number}</span>}
      {category && (
        <span>
          <span x-cloak x-show="lang==='es'">{category.es}</span>
          <span x-cloak x-show="lang==='en'">{category.en}</span>
        </span>
      )}
    </span>
    <span
      class:list={[
        'flex h-7 w-7 items-center justify-center rounded-full transition-transform duration-500 group-hover:rotate-[20deg]',
        variant === 'light' && 'bg-ink/5 text-ink group-hover:bg-flame group-hover:text-paper',
        variant === 'dark' && 'bg-paper/10 text-paper group-hover:bg-flame',
        variant === 'flame' && 'bg-paper/20 text-paper group-hover:bg-ink',
      ]}
    >
      <slot name="icon" />
    </span>
  </header>

  <div class="flex flex-1 flex-col p-6">
    <h3
      class:list={[
        'font-display-condensed text-2xl font-extrabold leading-tight tracking-tightest md:text-[1.7rem]',
      ]}
    >
      <span x-cloak x-show="lang==='es'">{title}</span>
      <span x-cloak x-show="lang==='en'">{titleEn}</span>
    </h3>

    <div
      class:list={[
        'mt-2 h-[2px] w-10 transition-all duration-500 group-hover:w-20',
        variant === 'light' && 'bg-ink',
        variant === 'dark' && 'bg-flame',
        variant === 'flame' && 'bg-paper',
      ]}
    ></div>

    <ul
      class:list={[
        'mt-5 flex-1 space-y-2.5 text-sm leading-relaxed',
        variant === 'light' && 'text-ink-muted',
        variant === 'dark' && 'text-paper/75',
        variant === 'flame' && 'text-paper/85',
      ]}
    >
      {bullets.map((b, i) => (
        <li class="flex items-start gap-2.5">
          <span
            class:list={[
              'mt-2 h-1 w-1 flex-shrink-0 rounded-full',
              variant === 'light' && 'bg-ink',
              variant === 'dark' && 'bg-flame',
              variant === 'flame' && 'bg-paper',
            ]}
          ></span>
          <span>
            <span x-cloak x-show="lang==='es'">{b}</span>
            <span x-cloak x-show="lang==='en'">{bulletsEn[i] ?? b}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</article>
