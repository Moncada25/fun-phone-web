---
const baseUrl = import.meta.env.BASE_URL;
---
<header class="fixed top-0 left-0 right-0 z-50" x-data="navbarComponent()" x-init="init()">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[999] focus:rounded-full focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:shadow-lg dark:focus:bg-neutral-900">
    Skip to content
  </a>
  <div class="mx-auto max-w-7xl px-4 pt-4">
    <nav
      id="navbar"
      data-base={baseUrl}
      class="relative flex items-center justify-between rounded-2xl border border-white/20 bg-white/60 px-5 py-3 shadow-lg shadow-black/[0.03] backdrop-blur-2xl transition-all duration-500 dark:border-white/[0.06] dark:bg-midnight/60 dark:shadow-black/20"
      :class="scrolled && 'border-accent/10 shadow-accent/5 dark:border-accent/10'"
      role="navigation"
    >
      <a href={baseUrl} class="group flex items-center gap-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-lg" aria-label="Fun Phone home">
        <div class="relative">
          <div class="absolute -inset-1 rounded-xl bg-gradient-to-br from-accent to-electric opacity-0 blur-sm transition-opacity duration-300 group-hover:opacity-60"></div>
          <img src={baseUrl + 'assets/logo.png'} width={36} height={36} alt="Fun Phone" class="relative rounded-xl shadow-sm" loading="eager" />
        </div>
        <div class="flex flex-col">
          <span class="font-display text-lg font-extrabold tracking-tight text-neutral-900 dark:text-white">Fun Phone</span>
          <span class="hidden text-[10px] font-semibold uppercase tracking-widest text-accent sm:block">Dialer & Contacts</span>
        </div>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        <a href={baseUrl + 'features/'} class="nav-link rounded-lg px-4 py-2 text-sm font-semibold text-neutral-600 transition-colors hover:bg-accent/5 hover:text-accent dark:text-neutral-300 dark:hover:bg-accent/10 dark:hover:text-accent" :class="isActive('features/') && 'bg-accent/5 text-accent dark:bg-accent/10'">
          <span x-show="currentLang==='es'">Funciones</span>
          <span x-show="currentLang==='en'">Features</span>
        </a>
        <a href={baseUrl + 'faq/'} class="nav-link rounded-lg px-4 py-2 text-sm font-semibold text-neutral-600 transition-colors hover:bg-accent/5 hover:text-accent dark:text-neutral-300 dark:hover:bg-accent/10 dark:hover:text-accent" :class="isActive('faq/') && 'bg-accent/5 text-accent dark:bg-accent/10'">
          FAQ
        </a>
        <a href={baseUrl + 'privacy/'} class="nav-link rounded-lg px-4 py-2 text-sm font-semibold text-neutral-600 transition-colors hover:bg-accent/5 hover:text-accent dark:text-neutral-300 dark:hover:bg-accent/10 dark:hover:text-accent" :class="isActive('privacy/') && 'bg-accent/5 text-accent dark:bg-accent/10'">
          <span x-show="currentLang==='es'">Privacidad</span>
          <span x-show="currentLang==='en'">Privacy</span>
        </a>
        <a href={baseUrl + 'roadmap/'} class="nav-link rounded-lg px-4 py-2 text-sm font-semibold text-neutral-600 transition-colors hover:bg-accent/5 hover:text-accent dark:text-neutral-300 dark:hover:bg-accent/10 dark:hover:text-accent" :class="isActive('roadmap/') && 'bg-accent/5 text-accent dark:bg-accent/10'">
          Roadmap
        </a>
      </div>

      <div class="hidden items-center gap-2 md:flex">
        <button type="button" @click="toggleLanguage()" class="flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-200/60 text-xs font-bold text-neutral-500 transition-all hover:border-accent/30 hover:text-accent dark:border-white/10 dark:text-neutral-400 dark:hover:border-accent/30 dark:hover:text-accent" :aria-label="currentLang==='es' ? 'Switch to English' : 'Cambiar a Espa\u00f1ol'">
          <span x-text="currentLang.toUpperCase()"></span>
        </button>
        <button type="button" @click="toggleTheme()" class="flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-200/60 text-neutral-500 transition-all hover:border-accent/30 hover:text-accent dark:border-white/10 dark:text-neutral-400 dark:hover:border-accent/30 dark:hover:text-accent" :aria-label="isDark ? 'Light mode' : 'Dark mode'" :aria-pressed="isDark.toString()">
          <svg x-show="!isDark" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/></svg>
          <svg x-show="isDark" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2m10-10h-2M4 12H2m15.364 6.364l-1.414-1.414M7.05 7.05L5.636 5.636m12.728 0L16.95 7.05M7.05 16.95l-1.414 1.414"/></svg>
        </button>
        <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" class="group relative inline-flex items-center gap-2 overflow-hidden rounded-xl bg-accent px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-accent/25 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/30 active:translate-y-0">
          <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full transition-transform duration-700 group-hover:translate-x-full"></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="relative h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.8.9-1.3 1.6-.8l14.4 8.5c.7.4.7 1.2 0 1.6L4.6 21.3c-.7.5-1.6 0-1.6-.8z"/></svg>
          <span class="relative" x-show="currentLang==='es'">Descargar</span>
          <span class="relative" x-show="currentLang==='en'">Download</span>
        </a>
      </div>

      <button type="button" class="flex h-10 w-10 items-center justify-center rounded-xl border border-neutral-200/60 text-neutral-600 transition-all hover:border-accent/30 hover:text-accent md:hidden dark:border-white/10 dark:text-neutral-300" @click="toggleMenu()" :aria-expanded="menuOpen.toString()" aria-controls="mobile-menu">
        <span class="sr-only">Menu</span>
        <svg x-show="!menuOpen" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg x-show="menuOpen" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </nav>
  </div>

  <div x-show="menuOpen" x-transition:enter="transition duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm md:hidden" @click.self="closeMenu()" @keydown.escape.window="menuOpen && closeMenu()" x-cloak>
    <div id="mobile-menu" class="ml-auto flex h-full w-80 max-w-[85vw] flex-col gap-6 overflow-y-auto border-l border-white/10 bg-white/95 px-6 py-8 shadow-2xl backdrop-blur-2xl dark:bg-midnight/95" x-transition:enter="transform transition duration-300" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0" x-transition:leave="transform transition duration-200" x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <img src={baseUrl + 'assets/logo.png'} width={28} height={28} alt="Fun Phone" class="rounded-lg" />
          <span class="font-display text-base font-bold text-neutral-900 dark:text-white">Fun Phone</span>
        </div>
        <button type="button" @click="closeMenu()" class="rounded-lg border border-neutral-200/60 p-2 text-neutral-500 hover:text-accent dark:border-white/10 dark:text-neutral-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="flex flex-col gap-1">
        <a href={baseUrl + 'features/'} @click="closeMenu()" class="rounded-xl px-4 py-3 text-sm font-semibold text-neutral-700 transition hover:bg-accent/5 hover:text-accent dark:text-neutral-200 dark:hover:bg-accent/10">
          <span x-show="currentLang==='es'">Funciones</span><span x-show="currentLang==='en'">Features</span>
        </a>
        <a href={baseUrl + 'faq/'} @click="closeMenu()" class="rounded-xl px-4 py-3 text-sm font-semibold text-neutral-700 transition hover:bg-accent/5 hover:text-accent dark:text-neutral-200 dark:hover:bg-accent/10">FAQ</a>
        <a href={baseUrl + 'privacy/'} @click="closeMenu()" class="rounded-xl px-4 py-3 text-sm font-semibold text-neutral-700 transition hover:bg-accent/5 hover:text-accent dark:text-neutral-200 dark:hover:bg-accent/10">
          <span x-show="currentLang==='es'">Privacidad</span><span x-show="currentLang==='en'">Privacy</span>
        </a>
        <a href={baseUrl + 'roadmap/'} @click="closeMenu()" class="rounded-xl px-4 py-3 text-sm font-semibold text-neutral-700 transition hover:bg-accent/5 hover:text-accent dark:text-neutral-200 dark:hover:bg-accent/10">Roadmap</a>
      </div>
      <div class="flex gap-2">
        <button type="button" @click="toggleLanguage()" class="flex-1 rounded-xl border border-neutral-200/60 py-3 text-sm font-bold text-neutral-600 transition hover:border-accent/30 hover:text-accent dark:border-white/10 dark:text-neutral-300">
          <span x-text="currentLang==='es' ? 'English' : 'Espa\u00f1ol'"></span>
        </button>
        <button type="button" @click="toggleTheme()" class="flex-1 rounded-xl border border-neutral-200/60 py-3 text-sm font-bold text-neutral-600 transition hover:border-accent/30 hover:text-accent dark:border-white/10 dark:text-neutral-300">
          <span x-text="isDark ? (currentLang==='es' ? 'Claro' : 'Light') : (currentLang==='es' ? 'Oscuro' : 'Dark')"></span>
        </button>
      </div>
      <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" @click="closeMenu()" class="flex items-center justify-center gap-2 rounded-xl bg-accent py-3.5 text-sm font-bold text-white shadow-lg shadow-accent/25">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.8.9-1.3 1.6-.8l14.4 8.5c.7.4.7 1.2 0 1.6L4.6 21.3c-.7.5-1.6 0-1.6-.8z"/></svg>
        <span x-show="currentLang==='es'">Descargar en Google Play</span>
        <span x-show="currentLang==='en'">Get on Google Play</span>
      </a>
    </div>
  </div>
</header>

<script is:inline>
function navbarComponent() {
  return {
    menuOpen: false,
    currentLang: localStorage.getItem('lang') || (navigator.language?.startsWith('es') ? 'es' : 'en'),
    isDark: (() => {
      const s = localStorage.getItem('darkMode');
      if (s !== null) return s === 'true';
      return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    })(),
    scrolled: false,
    init() {
      this.applyTheme();
      this.syncLang();
      window.addEventListener('scroll', () => { this.scrolled = window.scrollY > 20; }, { passive: true });
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (localStorage.getItem('darkMode') === null) { this.isDark = e.matches; this.applyTheme(); }
      });
      window.addEventListener('lang', (e) => {
        if (e.detail && e.detail !== this.currentLang) { this.currentLang = e.detail; localStorage.setItem('lang', this.currentLang); }
        this.updateDocLang();
      });
    },
    isActive(path) {
      try { return window.location.pathname.includes(path); } catch (_) { return false; }
    },
    toggleMenu() { this.menuOpen = !this.menuOpen; document.body.classList.toggle('overflow-hidden', this.menuOpen); },
    closeMenu() { this.menuOpen = false; document.body.classList.remove('overflow-hidden'); },
    toggleLanguage() { this.currentLang = this.currentLang === 'es' ? 'en' : 'es'; this.syncLang(); },
    syncLang() { localStorage.setItem('lang', this.currentLang); this.updateDocLang(); window.dispatchEvent(new CustomEvent('lang', { detail: this.currentLang })); },
    updateDocLang() { document.documentElement.lang = this.currentLang; document.documentElement.setAttribute('data-lang', this.currentLang); },
    toggleTheme() { this.isDark = !this.isDark; localStorage.setItem('darkMode', this.isDark); this.applyTheme(); },
    applyTheme() { document.documentElement.classList.toggle('dark', this.isDark); document.documentElement.style.colorScheme = this.isDark ? 'dark' : 'light'; }
  };
}
</script>
