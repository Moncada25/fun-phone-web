---
import Base from '../layouts/Base.astro';
import ScreenshotCarousel from '../components/ScreenshotCarousel.astro';
import ComparisonTable from '../components/ComparisonTable.astro';

const base = import.meta.env.BASE_URL;
const heroImg = base + 'assets/screenshots/favorites.png?v=4.0.0';

const stats = [
  { num: '12+', label: { es: 'Herramientas integradas', en: 'Built-in tools' } },
  { num: '10', label: { es: 'Minijuegos clásicos', en: 'Classic mini-games' } },
  { num: '0 KB', label: { es: 'Datos compartidos', en: 'Data shared' } },
  { num: 'GPL v3', label: { es: 'Open source', en: 'Open source' } },
];

const tools = [
  {
    num: '01',
    title: { es: 'Marcador T9', en: 'T9 Dialer' },
    desc: { es: 'Búsqueda instantánea, favoritos y Dual-SIM.', en: 'Instant search, favorites, and Dual-SIM.' },
    color: 'flame',
  },
  {
    num: '02',
    title: { es: 'Contactos Pro', en: 'Pro Contacts' },
    desc: { es: 'QR, importación vCard/JSON, anti-spam.', en: 'QR, vCard/JSON import, anti-spam.' },
    color: 'ink',
  },
  {
    num: '03',
    title: { es: 'Notas', en: 'Notes' },
    desc: { es: 'Markdown, checklists, audio y recordatorios.', en: 'Markdown, checklists, audio & reminders.' },
    color: 'ink',
  },
  {
    num: '04',
    title: { es: 'Vault', en: 'Vault' },
    desc: { es: 'Cifrado Tink, biometría y generador.', en: 'Tink encryption, biometrics & generator.' },
    color: 'flame',
  },
  {
    num: '05',
    title: { es: 'Gastos', en: 'Expenses' },
    desc: { es: 'Categorías, presupuestos y análisis.', en: 'Categories, budgets & analytics.' },
    color: 'ink',
  },
  {
    num: '06',
    title: { es: 'Ciclo', en: 'Cycle' },
    desc: { es: 'Predicciones y bienestar privado.', en: 'Predictions & private wellness.' },
    color: 'ink',
  },
  {
    num: '07',
    title: { es: 'Académica', en: 'Academic' },
    desc: { es: 'Materias, notas, tareas y asistencia.', en: 'Subjects, grades, tasks & attendance.' },
    color: 'flame',
  },
  {
    num: '08',
    title: { es: 'Pomodoro', en: 'Pomodoro' },
    desc: { es: '25/5, configurable, en segundo plano.', en: '25/5, customizable, runs in background.' },
    color: 'ink',
  },
  {
    num: '09',
    title: { es: 'Voz + QR', en: 'Voice + QR' },
    desc: { es: 'STT, TTS, escáner y generador.', en: 'STT, TTS, scanner & generator.' },
    color: 'ink',
  },
  {
    num: '10',
    title: { es: 'Festivos', en: 'Holidays' },
    desc: { es: 'API Nager.Date, países y años.', en: 'Nager.Date API, countries & years.' },
    color: 'flame',
  },
  {
    num: '11',
    title: { es: 'Juegos', en: 'Games' },
    desc: { es: 'Snake, 2048, Sudoku, Memory y más.', en: 'Snake, 2048, Sudoku, Memory & more.' },
    color: 'ink',
  },
  {
    num: '12',
    title: { es: 'Pintura', en: 'Paint' },
    desc: { es: 'Pinceles expresivos, exportar y compartir.', en: 'Expressive brushes, export & share.' },
    color: 'ink',
  },
];

const marqueeItems = [
  { es: 'Fun Phone', en: 'Fun Phone', accent: true },
  { es: 'Open source', en: 'Open source' },
  { es: 'GPL v3', en: 'GPL v3' },
  { es: 'Sin anuncios', en: 'Ad-free' },
  { es: 'Privacidad real', en: 'Real privacy' },
  { es: 'Cero servidores', en: 'Zero servers' },
  { es: 'Cifrado Tink', en: 'Tink encryption' },
  { es: '★ 5.0 en Play Store', en: '★ 5.0 on Play Store' },
];
---

<Base
  title="Fun Phone — The Android Dialer that does more"
  description="Fun Phone combines an advanced dialer, smart contacts, productivity tools, games, password manager and more. Free on Google Play. No ads. No data sharing."
  ogImage={heroImg}
  canonical="https://moncada25.github.io/fun-phone-web/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Fun Phone: Dialer & Contacts",
    "operatingSystem": "Android",
    "applicationCategory": "CommunicationApplication",
    "inLanguage": ["es", "en"],
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "downloadUrl": "https://play.google.com/store/apps/details?id=com.bookverse.contacts",
    "author": { "@type": "Organization", "name": "Bookverse" },
    "privacyPolicy": "https://moncada25.github.io/fun-phone-web/privacy/"
  })}></script>

  <!-- ======================== -->
  <!-- HERO MARQUEE -->
  <!-- ======================== -->
  <section class="relative border-b border-ink/15 overflow-hidden">
    <div class="marquee-track py-5">
      {[0, 1].map(() => (
        <div class="flex shrink-0 items-center gap-8 pr-8 font-display-condensed text-[1.5rem] font-extrabold uppercase leading-none tracking-tightest md:text-[2rem]">
          {marqueeItems.map((item) => (
            <Fragment>
              <span class:list={[item.accent ? 'text-flame' : 'text-ink']} x-cloak x-show={`lang==='es'`}>{item.es}</span>
              <span class:list={[item.accent ? 'text-flame' : 'text-ink']} x-cloak x-show={`lang==='en'`}>{item.en}</span>
              <span class="text-flame">✱</span>
            </Fragment>
          ))}
          <span class="font-serif-italic text-flame lowercase">on-device only</span>
          <span class="text-flame">✱</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ======================== -->
  <!-- HERO -->
  <!-- ======================== -->
  <section class="relative overflow-hidden">
    <div class="container-editorial relative pb-24 pt-12 md:pb-32 md:pt-20">
      <!-- Editorial grid -->
      <div class="grid grid-cols-12 gap-6 md:gap-10">
        <!-- LEFT META -->
        <div class="col-span-12 flex flex-col gap-4 md:col-span-3 reveal">
          <div class="mt-4 flex items-center gap-2">
            <span class="flex h-2 w-2">
              <span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-flame opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-flame"></span>
            </span>
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink">
              <span x-cloak x-show="lang==='es'">Gratis en Play Store · 5.0★</span>
              <span x-cloak x-show="lang==='en'">Free on Play Store · 5.0★</span>
            </span>
          </div>
        </div>

        <!-- CENTER HEADLINE -->
        <div class="col-span-12 md:col-span-9">
          <h1 class="reveal text-balance font-display-condensed text-[3rem] font-extrabold leading-[0.92] tracking-tightest text-ink sm:text-[4.5rem] md:text-[6.5rem] lg:text-[7.5rem]">
            <span class="block">
              <span x-cloak x-show="lang==='es'">Tu central</span>
              <span x-cloak x-show="lang==='en'">Your hub</span>
            </span>
            <span class="block">
              <span x-cloak x-show="lang==='es'">de </span>
              <span x-cloak x-show="lang==='en'">for </span>
              <span class="font-serif-italic text-flame">
                <span x-cloak x-show="lang==='es'">comunicación</span>
                <span x-cloak x-show="lang==='en'">communication</span>
              </span>
              <span class="font-serif-italic text-ink">
                <span x-cloak x-show="lang==='es'">&amp;</span>
                <span x-cloak x-show="lang==='en'">&amp;</span>
              </span>
            </span>
            <span class="block">
              <span x-cloak x-show="lang==='es'">productividad,</span>
              <span x-cloak x-show="lang==='en'">productivity,</span>
            </span>
            <span class="block">
              <span x-cloak x-show="lang==='es'">en una app.</span>
              <span x-cloak x-show="lang==='en'">in one app.</span>
            </span>
          </h1>
        </div>

        <!-- SUBHEAD + CTA ROW -->
        <div class="col-span-12 md:col-start-4 md:col-span-9 reveal">
          <div class="grid gap-8 md:grid-cols-2 md:items-end">
            <p class="max-w-md text-pretty text-base leading-relaxed text-ink-muted md:text-lg">
              <span x-cloak x-show="lang==='es'">Marcador avanzado, contactos, notas, gastos, contraseñas cifradas, Pomodoro, gestión académica, juegos y más. <b class="text-ink">Open source bajo GPL v3</b>. Sin anuncios. Sin datos compartidos.</span>
              <span x-cloak x-show="lang==='en'">Advanced dialer, contacts, notes, expenses, encrypted passwords, Pomodoro, academic management, games and more. <b class="text-ink">Open source under GPL v3</b>. No ads. No data sharing.</span>
            </p>
            <div class="flex flex-wrap items-center gap-3">
              <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" class="btn-primary group">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
                  <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893 2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4 2.545 1.474c.879.51.879 1.69 0 2.2l-2.545 1.474-2.626-2.262 2.626-2.262zM5.864 2.658 16.802 8.99l-2.302 2.302L5.864 2.658z"/>
                </svg>
                <span x-cloak x-show="lang==='es'">Instalar gratis</span>
                <span x-cloak x-show="lang==='en'">Install free</span>
                <span class="ml-1 flex h-5 w-5 items-center justify-center rounded-full bg-paper/20 font-mono text-[0.6rem]">↗</span>
              </a>
              <a href="https://github.com/Moncada25/fun-phone" target="_blank" rel="noopener" class="btn-ghost group">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.6 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.8-1.6 8.2-6.1 8.2-11.4C24 5.9 18.6.5 12 .5z"/></svg>
                <span>GitHub</span>
                <span class="font-mono text-xs">★</span>
              </a>
              <a href={base + 'features/'} class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-ink-muted underline-link">
                <span x-cloak x-show="lang==='es'">Ver funciones</span>
                <span x-cloak x-show="lang==='en'">See features</span>
                <span>→</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- HERO IMAGE STAGE -->
      <div class="mt-16 grid grid-cols-12 gap-6 md:mt-24 md:gap-10">
        <!-- Caption block -->
        <div class="col-span-12 flex flex-col justify-end md:col-span-4 reveal">
          <div class="border-t border-ink/20 pt-4">
            <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">Fig. 01</p>
            <p class="mt-2 font-display text-base font-bold text-ink">
              <span x-cloak x-show="lang==='es'">La pantalla de Favoritos, recién salida del estudio.</span>
              <span x-cloak x-show="lang==='en'">The Favorites screen, fresh from the studio.</span>
            </p>
            <p class="mt-1 text-xs text-ink-muted">
              <span x-cloak x-show="lang==='es'">Atajos a las personas que más importan. Sin pestañas escondidas, sin bloatware.</span>
              <span x-cloak x-show="lang==='en'">Shortcuts to the people who matter. No hidden tabs, no bloatware.</span>
            </p>
          </div>

          <!-- Floating chip -->
          <div class="mt-8 inline-flex items-center gap-3 self-start border border-ink bg-ink px-4 py-2.5 text-paper" style="border-radius: 999px;">
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em]">Android 9+</span>
            <span class="h-3 w-px bg-paper/30"></span>
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-flame">v3.16.1</span>
            <span class="h-3 w-px bg-paper/30"></span>
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em]">GPL v3</span>
          </div>
        </div>

        <!-- Phone stage -->
        <div class="col-span-12 md:col-span-8 reveal">
          <div class="relative">
            <!-- Annotation labels (decorative) -->
            <div class="absolute -left-2 top-12 hidden -rotate-12 md:block">
              <span class="font-serif-italic text-2xl text-flame">your people</span>
              <svg class="ml-12 -mt-2 h-10 w-24" viewBox="0 0 100 40" fill="none">
                <path d="M5 35 Q 30 5, 90 20" stroke="#FF4D1A" stroke-width="1.5" stroke-linecap="round" fill="none" class="scribble-arrow"/>
                <path d="M88 16 L 92 21 L 86 23" stroke="#FF4D1A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>

            <div
              class="relative mx-auto w-full max-w-[480px] overflow-hidden border border-ink/15 bg-gradient-to-b from-paper-soft to-paper"
              style="border-radius: 36px; box-shadow: 0 30px 80px -30px rgba(10,10,10,0.4), 0 0 0 1px rgba(10,10,10,0.04);"
            >
              <img src={heroImg} alt="Fun Phone app screenshot" class="block h-auto w-full" loading="eager" width="540" height="1080" />
            </div>

            <!-- Bottom labels -->
            <div class="absolute -right-2 bottom-8 hidden rotate-6 md:block">
              <span class="font-serif-italic text-xl text-ink">0% cloud. 100% yours.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Decorative ticker line -->
    <div class="hairline-b border-ink/15"></div>
  </section>

  <!-- ======================== -->
  <!-- STATS BAR -->
  <!-- ======================== -->
  <section class="border-b border-ink/15 py-10 md:py-14">
    <div class="container-editorial">
      <div class="mb-6 flex items-center gap-3">
        <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">
          <span x-cloak x-show="lang==='es'">Cifras</span>
          <span x-cloak x-show="lang==='en'">By the numbers</span>
        </span>
        <span class="h-px flex-1 bg-ink/15"></span>
        <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">2026</span>
      </div>
      <div class="grid grid-cols-2 gap-px overflow-hidden border border-ink/15 bg-ink/15 md:grid-cols-4" style="border-radius: 20px;">
        {stats.map((stat, i) => (
          <div class="group relative flex flex-col gap-2 bg-paper p-6 transition-colors hover:bg-flame md:p-8">
            <span class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost transition-colors group-hover:text-paper/80">{(i + 1).toString().padStart(2, '0')}</span>
            <span class="font-display-condensed text-5xl font-extrabold leading-none tracking-tighter text-ink transition-colors group-hover:text-paper md:text-6xl">{stat.num}</span>
            <span class="mt-1 text-xs font-semibold text-ink-muted transition-colors group-hover:text-paper/85">
              <span x-cloak x-show="lang==='es'">{stat.label.es}</span>
              <span x-cloak x-show="lang==='en'">{stat.label.en}</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- MANIFESTO QUOTE -->
  <!-- ======================== -->
  <section class="relative py-20 md:py-32">
    <div class="container-editorial">
      <div class="mx-auto max-w-5xl text-center reveal">
        <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">
          <span x-cloak x-show="lang==='es'">Manifiesto</span>
          <span x-cloak x-show="lang==='en'">Manifesto</span>
        </p>
        <blockquote class="mt-8 text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.96] tracking-tightest text-ink md:text-[4rem] lg:text-[5rem]">
          <span x-cloak x-show="lang==='es'">Una app </span>
          <span x-cloak x-show="lang==='en'">An app </span>
          <span class="font-serif-italic text-flame">
            <span x-cloak x-show="lang==='es'">open source</span>
            <span x-cloak x-show="lang==='en'">open source</span>
          </span>
          <span x-cloak x-show="lang==='es'"> que no te rastrea,</span>
          <span x-cloak x-show="lang==='en'"> that doesn't track you,</span>
          <br />
          <span x-cloak x-show="lang==='es'">que respeta tu batería </span>
          <span x-cloak x-show="lang==='en'">that respects your battery </span>
          <span class="font-serif-italic text-ink">
            <span x-cloak x-show="lang==='es'">y tu tiempo.</span>
            <span x-cloak x-show="lang==='en'">and your time.</span>
          </span>
        </blockquote>
        <div class="mt-10 flex items-center justify-center gap-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-ghost">
          <span class="h-px w-12 bg-ink/30"></span>
          <span>
            <span x-cloak x-show="lang==='es'">— Fun Phone · GPL v3 · Bookverse</span>
            <span x-cloak x-show="lang==='en'">— Fun Phone · GPL v3 · Bookverse</span>
          </span>
          <span class="h-px w-12 bg-ink/30"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- TOOLS GRID -->
  <!-- ======================== -->
  <section class="relative border-y border-ink/15 bg-paper-soft/40 py-20 md:py-28">
    <div class="container-editorial">
      <div class="mb-12 mx-auto max-w-4xl text-center">
        <h2 class="text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.96] tracking-tightest text-ink md:text-[3.5rem] lg:text-[4.5rem]">
          <span x-cloak x-show="lang==='es'">Doce herramientas, </span>
          <span x-cloak x-show="lang==='en'">Twelve tools, </span>
          <span class="font-serif-italic text-flame">
            <span x-cloak x-show="lang==='es'">una sola app.</span>
            <span x-cloak x-show="lang==='en'">one single app.</span>
          </span>
        </h2>
        <p class="mt-4 max-w-2xl mx-auto text-pretty text-base text-ink-muted">
          <span x-cloak x-show="lang==='es'">Todo lo esencial para llamar, organizar, jugar y crear — sin cambiar de app cada cinco minutos.</span>
          <span x-cloak x-show="lang==='en'">Everything you need to call, organize, play and create — without bouncing between five different apps.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <article
            class:list={[
              'group relative flex flex-col gap-4 border bg-paper p-6 transition-all duration-500 hover:-translate-y-1',
              tool.color === 'flame' ? 'border-ink hover:border-flame' : 'border-ink/15 hover:border-ink',
            ]}
            style="border-radius: 18px;"
          >
            <header class="flex items-center justify-between">
              <span class:list={['font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em]', tool.color === 'flame' ? 'text-flame' : 'text-ink-ghost']}>{tool.num}</span>
              <span class:list={['flex h-7 w-7 items-center justify-center rounded-full transition-all duration-500 group-hover:rotate-45', tool.color === 'flame' ? 'bg-flame text-paper' : 'bg-ink/5 text-ink group-hover:bg-ink group-hover:text-paper']}>
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </span>
            </header>
            <div>
              <h3 class="font-display-condensed text-2xl font-extrabold leading-tight tracking-tightest text-ink">
                <span x-cloak x-show="lang==='es'">{tool.title.es}</span>
                <span x-cloak x-show="lang==='en'">{tool.title.en}</span>
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">
                <span x-cloak x-show="lang==='es'">{tool.desc.es}</span>
                <span x-cloak x-show="lang==='en'">{tool.desc.en}</span>
              </p>
            </div>
            <div class:list={['mt-auto h-px transition-all duration-500 group-hover:w-full', tool.color === 'flame' ? 'w-12 bg-flame' : 'w-12 bg-ink/20 group-hover:bg-ink']}></div>
          </article>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a href={base + 'features/'} class="inline-flex items-center gap-2 border-b-2 border-ink pb-1 font-display text-base font-bold text-ink transition-colors hover:border-flame hover:text-flame">
          <span x-cloak x-show="lang==='es'">Ver el índice completo</span>
          <span x-cloak x-show="lang==='en'">See the full index</span>
          <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ======================== -->
  <!-- SCREENSHOTS -->
  <!-- ======================== -->
  <section class="relative py-20 md:py-32">
    <div class="container-editorial">
      <ScreenshotCarousel />
    </div>
  </section>

  <!-- ======================== -->
  <!-- COMPARISON -->
  <!-- ======================== -->
  <section class="relative border-y border-ink/15 py-20 md:py-28">
    <div class="container-editorial">
      <div class="mb-12 mx-auto max-w-4xl text-center">
        <h2 class="text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.96] tracking-tightest text-ink md:text-[3.5rem] lg:text-[4.5rem]">
          <span x-cloak x-show="lang==='es'">Tu marcador </span>
          <span x-cloak x-show="lang==='en'">Your stock dialer </span>
          <span class="font-serif-italic text-flame">
            <span x-cloak x-show="lang==='es'">solo marca.</span>
            <span x-cloak x-show="lang==='en'">just dials.</span>
          </span>
          <br />
