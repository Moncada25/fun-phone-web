---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PrivacyBadge from '../../components/PrivacyBadge.astro';
import PermissionsBlock from '../../components/PermissionsBlock.astro';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://moncada25.github.io/fun-phone-web/privacy/';
const lastUpdated = '3 sep 2025';
const lastUpdatedEn = 'Sep 3, 2025';
---
<!DOCTYPE html>
<html lang="es" x-data="pageState()" x-on:lang.window="updateLang($event.detail)" x-bind:lang="lang" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Privacy Policy | Fun Phone: Dialer & Contacts</title>
    <meta name="description" content="Fun Phone privacy policy: how we handle your data, permissions, storage, and controls available to you." />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" href={siteUrl} hreflang="es" />
    <link rel="alternate" href={siteUrl} hreflang="en" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Fun Phone" />
    <meta property="og:title" content="Fun Phone Privacy Policy" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    <link rel="icon" type="image/png" href={base + 'assets/logo.png'} />
    <link rel="apple-touch-icon" href={base + 'assets/logo.png'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script>
      const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
      const saved = localStorage.getItem('darkMode');
      const isDark = saved !== null ? saved === 'true' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak]{display:none!important}</style>
  </head>
  <body class="font-body bg-white text-neutral-900 antialiased dark:bg-midnight dark:text-neutral-100">
    <Navbar />
    <main id="main-content" class="mx-auto max-w-5xl px-6 pt-28 pb-20">
      <header class="py-16 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent">
          <span x-show="lang==='es'">Privacidad real</span>
          <span x-show="lang==='en'">Real privacy</span>
        </p>
        <h1 class="mt-4 font-display text-4xl font-black tracking-tight sm:text-5xl">
          <span x-show="lang==='es'" class="text-neutral-900 dark:text-white">Pol&iacute;tica de <span class="text-accent">privacidad</span></span>
          <span x-show="lang==='en'" class="text-neutral-900 dark:text-white">Privacy <span class="text-accent">policy</span></span>
        </h1>
        <div class="mt-6 flex flex-col items-center gap-3">
          <PrivacyBadge />
          <p class="text-sm text-neutral-500 dark:text-neutral-400">
            <span x-show="lang==='es'"><b>Actualizado:</b> {lastUpdated}</span>
            <span x-show="lang==='en'"><b>Updated:</b> {lastUpdatedEn}</span>
          </p>
        </div>
      </header>

      <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
        <article class="space-y-6">
          <section id="about" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400" x-show="lang==='es'">
              <em>Fun Phone</em> es una app de tel&eacute;fono/dialer y contactos. Al configurarla como <b>app de Tel&eacute;fono predeterminada</b>, puedes realizar, contestar y gestionar llamadas y contactos.
            </p>
            <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400" x-show="lang==='en'">
              <em>Fun Phone</em> is a dialer and contacts app. When set as your <b>default Phone app</b>, it lets you place, receive, and manage calls and contacts.
            </p>
          </section>

          <section id="data" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">1. Datos que tratamos</span>
              <span x-show="lang==='en'">1. Data we process</span>
            </h2>
            <ul class="mt-4 space-y-3 text-sm text-neutral-600 dark:text-neutral-400">
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span><strong>Contacts</strong> <span x-show="lang==='es'">&mdash; leer, crear, editar y eliminar.</span><span x-show="lang==='en'">&mdash; read, create, edit, and delete.</span></span></li>
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span><strong>Call log</strong> <span x-show="lang==='es'">&mdash; leer/escribir historial como app predeterminada.</span><span x-show="lang==='en'">&mdash; read/write history as default app.</span></span></li>
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span><strong>Phone state</strong> <span x-show="lang==='es'">&mdash; identificar l&iacute;nea activa y estado.</span><span x-show="lang==='en'">&mdash; identify active line and state.</span></span></li>
            </ul>
          </section>

          <section id="purpose" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">2. Finalidad</span>
              <span x-show="lang==='en'">2. Purpose</span>
            </h2>
            <ul class="mt-4 space-y-2 text-sm text-neutral-600 dark:text-neutral-400">
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Mostrar y gestionar llamadas recientes.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Display and manage recent calls.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Realizar o contestar llamadas.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Place or answer calls.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Sincronizar nombres con el historial.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Sync contact names with call history.</span></li>
            </ul>
          </section>

          <section id="storage" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">3. Almacenamiento</span>
              <span x-show="lang==='en'">3. Storage</span>
            </h2>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400" x-show="lang==='es'">Los datos permanecen en tu dispositivo Android. No se transfieren a servidores propios.</p>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400" x-show="lang==='en'">Data stays on your device. We do not transfer data to our servers.</p>
          </section>

          <section id="sharing" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">4. Compartici&oacute;n</span>
              <span x-show="lang==='en'">4. Sharing</span>
            </h2>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400" x-show="lang==='es'">No vendemos ni compartimos datos con terceros.</p>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400" x-show="lang==='en'">We do not sell or share data with third parties.</p>
          </section>

          <section id="permissions" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="mb-4 font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">5. Permisos</span>
              <span x-show="lang==='en'">5. Permissions</span>
            </h2>
            <PermissionsBlock />
          </section>

          <section id="controls" class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">
              <span x-show="lang==='es'">6. Tus controles</span>
              <span x-show="lang==='en'">6. Your controls</span>
            </h2>
            <ul class="mt-4 space-y-2 text-sm text-neutral-600 dark:text-neutral-400">
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Revocar permisos: Ajustes &rarr; Apps &rarr; Fun Phone &rarr; Permisos.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Revoke permissions: Settings &rarr; Apps &rarr; Fun Phone &rarr; Permissions.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Quitar como predeterminado: Ajustes &rarr; Apps predeterminadas.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Remove as default: Settings &rarr; Default apps.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='es'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Eliminar datos: gestionar historial o desinstalar.</span></li>
              <li class="flex items-start gap-2" x-show="lang==='en'"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent"></span><span>Delete data: manage call log or uninstall.</span></li>
            </ul>
          </section>
        </article>

        <aside class="sticky top-28 hidden h-fit space-y-6 rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02] lg:block">
          <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-400 dark:text-neutral-500">
            <span x-show="lang==='es'">Resumen</span>
            <span x-show="lang==='en'">Summary</span>
          </h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between"><dt class="text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">Datos compartidos</dt><dt class="text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">Data shared</dt><dd class="font-bold text-accent">0</dd></div>
            <div class="flex justify-between"><dt class="text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">Almacenamiento</dt><dt class="text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">Storage</dt><dd class="font-bold text-accent">100% local</dd></div>
          </dl>
          <nav class="space-y-1 text-sm" x-data="{ sections: [
            { id:'about', es:'Sobre la app', en:'About' },
            { id:'data', es:'Datos', en:'Data' },
            { id:'purpose', es:'Finalidad', en:'Purpose' },
            { id:'storage', es:'Almacenamiento', en:'Storage' },
            { id:'sharing', es:'Compartici\u00f3n', en:'Sharing' },
            { id:'permissions', es:'Permisos', en:'Permissions' },
            { id:'controls', es:'Controles', en:'Controls' }
          ]}">
            <template x-for="s in sections" :key="s.id">
              <a :href="'#'+s.id" class="block rounded-lg px-3 py-2 text-neutral-500 transition hover:bg-accent/5 hover:text-accent dark:text-neutral-400 dark:hover:bg-accent/10" x-text="lang==='es' ? s.es : s.en"></a>
            </template>
          </nav>
          <div class="rounded-xl border border-dashed border-accent/20 bg-accent/5 p-4 text-xs text-neutral-500 dark:border-accent/30 dark:bg-accent/10 dark:text-neutral-400">
            <p x-show="lang==='es'">Dudas: <a href="mailto:santiago.moncada.dev@gmail.com" class="text-accent hover:underline">santiago.moncada.dev@gmail.com</a></p>
            <p x-show="lang==='en'">Questions: <a href="mailto:santiago.moncada.dev@gmail.com" class="text-accent hover:underline">santiago.moncada.dev@gmail.com</a></p>
          </div>
        </aside>
      </div>
    </main>
    <Footer />
    <script is:inline>
      function pageState() {
        return {
          lang: localStorage.getItem('lang') || (navigator.language?.startsWith('es') ? 'es' : 'en'),
          init() { document.documentElement.setAttribute('data-lang', this.lang); },
          updateLang(v) { if (!v) return; this.lang = v; document.documentElement.setAttribute('data-lang', this.lang); }
        };
      }
    </script>
  </body>
</html>
