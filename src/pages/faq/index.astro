---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQBlock from '../../components/FAQBlock.astro';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://moncada25.github.io/fun-phone-web/faq/';

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I set Fun Phone as default?', acceptedAnswer: { '@type': 'Answer', text: 'Go to Settings > Default apps > Phone and select Fun Phone.' } },
    { '@type': 'Question', name: 'What games are included?', acceptedAnswer: { '@type': 'Answer', text: '10 classic mini-games: Fun Bird, Snake, Minesweeper, 2048, Puzzle, Tic-Tac-Toe, Hangman, Breakout, Sudoku, Memory, plus a Paint Studio.' } },
    { '@type': 'Question', name: 'Does it have ads?', acceptedAnswer: { '@type': 'Answer', text: 'No. Fun Phone is completely ad-free.' } },
    { '@type': 'Question', name: 'Is any data shared?', acceptedAnswer: { '@type': 'Answer', text: 'No. Per Google Play: No data shared with third parties and No data collected.' } },
  ]
});
---
<!DOCTYPE html>
<html lang="es" x-data="pageState()" x-on:lang.window="updateLang($event.detail)" x-bind:lang="lang" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>FAQ | Fun Phone: Dialer & Contacts</title>
    <meta name="description" content="Frequently asked questions about Fun Phone: setup, privacy, permissions, games and support." />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" href={siteUrl} hreflang="es" />
    <link rel="alternate" href={siteUrl} hreflang="en" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Fun Phone" />
    <meta property="og:title" content="FAQ Fun Phone" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    <link rel="icon" type="image/png" href={base + 'assets/logo.png'} />
    <link rel="apple-touch-icon" href={base + 'assets/logo.png'} />
    <script type="application/ld+json" set:html={faqSchema}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script>
      const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
      const saved = localStorage.getItem('darkMode');
      const isDark = saved !== null ? saved === 'true' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak]{display:none!important}</style>
  </head>
  <body class="font-body bg-white text-neutral-900 antialiased dark:bg-midnight dark:text-neutral-100">
    <Navbar />
    <main id="main-content" class="mx-auto max-w-3xl px-6 pt-28 pb-20">
      <header class="py-16 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent">
          <span x-show="lang==='es'">Ayuda r&aacute;pida</span>
          <span x-show="lang==='en'">Quick help</span>
        </p>
        <h1 class="mt-4 font-display text-4xl font-black tracking-tight sm:text-5xl">
          <span x-show="lang==='es'" class="text-neutral-900 dark:text-white">Preguntas <span class="text-accent">frecuentes</span></span>
          <span x-show="lang==='en'" class="text-neutral-900 dark:text-white">Frequently asked <span class="text-accent">questions</span></span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">
          Todo lo que necesitas saber para sacar el m&aacute;ximo provecho de Fun Phone.
        </p>
        <p class="mx-auto mt-5 max-w-xl text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">
          Everything you need to know to get the most out of Fun Phone.
        </p>
      </header>

      <div class="grid gap-4 pb-10 sm:grid-cols-3">
        <div class="rounded-2xl border border-neutral-200/60 bg-white/60 p-5 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='es'">Primeros pasos</p>
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='en'">Getting started</p>
          <p class="mt-2 text-xs text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">Ajustes &rarr; Apps predeterminadas &rarr; Tel&eacute;fono &rarr; Fun Phone.</p>
          <p class="mt-2 text-xs text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">Settings &rarr; Default apps &rarr; Phone &rarr; Fun Phone.</p>
        </div>
        <div class="rounded-2xl border border-neutral-200/60 bg-white/60 p-5 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='es'">Soporte</p>
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='en'">Support</p>
          <p class="mt-2 text-xs text-neutral-500 dark:text-neutral-400"><a href="mailto:santiago.moncada.dev@gmail.com" class="text-accent hover:underline">santiago.moncada.dev@gmail.com</a></p>
        </div>
        <div class="rounded-2xl border border-neutral-200/60 bg-white/60 p-5 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='es'">Idioma</p>
          <p class="font-display text-sm font-bold text-neutral-900 dark:text-white" x-show="lang==='en'">Language</p>
          <p class="mt-2 text-xs text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">Cambia desde la barra superior o Ajustes &rarr; Idioma.</p>
          <p class="mt-2 text-xs text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">Switch from the top bar or Settings &rarr; Language.</p>
        </div>
      </div>

      <FAQBlock />

      <section class="mt-12 rounded-2xl border border-neutral-200/60 bg-white/60 p-8 text-center backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
        <p class="font-display text-lg font-bold text-neutral-900 dark:text-white" x-show="lang==='es'">&iquest;No encuentras tu respuesta?</p>
        <p class="font-display text-lg font-bold text-neutral-900 dark:text-white" x-show="lang==='en'">Can&apos;t find your answer?</p>
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">Consulta la <a href={base + 'privacy/'} class="text-accent hover:underline">pol&iacute;tica de privacidad</a> o escr&iacute;benos con tu dispositivo y versi&oacute;n de Android.</p>
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">Check the <a href={base + 'privacy/'} class="text-accent hover:underline">privacy policy</a> or email us with your device and Android version.</p>
      </section>
    </main>
    <Footer />
    <script is:inline>
      function pageState() {
        return {
          lang: localStorage.getItem('lang') || (navigator.language?.startsWith('es') ? 'es' : 'en'),
          init() { document.documentElement.setAttribute('data-lang', this.lang); },
          updateLang(v) { if (!v) return; this.lang = v; document.documentElement.setAttribute('data-lang', this.lang); }
        };
      }
    </script>
  </body>
</html>
