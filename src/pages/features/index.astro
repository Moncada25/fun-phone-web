---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://moncada25.github.io/fun-phone-web/features/';
const ssBase = base + 'assets/screenshots/';
const v = '?v=4.0.0';
---
<!DOCTYPE html>
<html lang="es" x-data="pageState()" x-on:lang.window="updateLang($event.detail)" x-bind:lang="lang" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Features | Fun Phone: Dialer & Contacts</title>
    <meta name="description" content="Explore all Fun Phone features: advanced dialer, smart contacts, productivity suite, password manager, expense tracker, games and more." />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" href={siteUrl} hreflang="es" />
    <link rel="alternate" href={siteUrl} hreflang="en" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Fun Phone" />
    <meta property="og:title" content="Fun Phone Features" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    <link rel="icon" type="image/png" href={base + 'assets/logo.png'} />
    <link rel="apple-touch-icon" href={base + 'assets/logo.png'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script>
      const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
      const saved = localStorage.getItem('darkMode');
      const isDark = saved !== null ? saved === 'true' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
      [x-cloak] { display: none !important; }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
    </style>
  </head>
  <body class="font-body bg-white text-neutral-900 antialiased dark:bg-midnight dark:text-neutral-100">
    <Navbar />

    <main id="main-content" class="mx-auto max-w-7xl px-6 pt-28 pb-20">
      <!-- HERO -->
      <header class="relative mx-auto max-w-3xl py-16 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent">
          <span x-show="lang==='es'">Todo lo que incluye</span>
          <span x-show="lang==='en'">Everything included</span>
        </p>
        <h1 class="mt-4 font-display text-4xl font-black tracking-tight sm:text-5xl">
          <span x-show="lang==='es'" class="text-neutral-900 dark:text-white">Funciones que <span class="bg-gradient-to-r from-accent to-electric bg-clip-text text-transparent">transforman</span></span>
          <span x-show="lang==='en'" class="text-neutral-900 dark:text-white">Features that <span class="bg-gradient-to-r from-accent to-electric bg-clip-text text-transparent">transform</span></span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-lg text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">
          Explora las herramientas integradas que convierten a Fun Phone en mucho m&aacute;s que un marcador.
        </p>
        <p class="mx-auto mt-5 max-w-xl text-lg text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">
          Explore the built-in tools that make Fun Phone much more than a dialer.
        </p>
      </header>

      <!-- COMMUNICATION -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92V19a2 2 0 01-2.18 2A19.72 19.72 0 013 5.18 2 2 0 015 3h2a2 2 0 012 1.72c.13 1.23.37 2.44.7 3.62a2 2 0 01-.45 2.11l-1.27 1.27a16 16 0 007.07 7.07l1.27-1.27a2 2 0 012.11-.45c1.18.33 2.39.57 3.62.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Comunicaci&oacute;n</span>
            <span x-show="lang==='en'">Communication</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <FeatureBlock title="Marcador Avanzado" titleEn="Advanced Dialer" bullets={['B\u00fasqueda T9 inteligente y marcado r\u00e1pido.','Historial con filtros, favoritos y b\u00fasqueda.','Interfaz pro: retener, silenciar, altavoz.','Dual-SIM y enrutamiento inteligente.','Marcado por voz y sensor de proximidad.']} bulletsEn={['Smart T9 search with fast dialing.','Call history with filters, favorites & search.','Pro controls: hold, mute, speaker.','Dual-SIM with smart routing.','Voice dialing & proximity sensor.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92V19a2 2 0 01-2.18 2A19.72 19.72 0 013 5.18 2 2 0 015 3h2a2 2 0 012 1.72c.13 1.23.37 2.44.7 3.62a2 2 0 01-.45 2.11l-1.27 1.27a16 16 0 007.07 7.07l1.27-1.27a2 2 0 012.11-.45c1.18.33 2.39.57 3.62.7A2 2 0 0122 16.92z"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Privacidad Primero" titleEn="Privacy First" bullets={['Permisos granulares con explicaciones claras.','Datos locales, nunca compartidos.','Sin anuncios invasivos.','Control total sobre acceso y permisos.']} bulletsEn={['Granular permissions with clear explanations.','Local data, never shared.','No invasive ads.','Full control over access & permissions.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- SCREENSHOT BREAK -->
      <div class="flex justify-center py-8">
        <div class="overflow-hidden rounded-2xl border border-neutral-200/60 shadow-xl dark:border-white/10">
          <img src={ssBase + 'favorites.png' + v} alt="Fun Phone contacts" class="h-[360px] w-auto object-contain" loading="lazy" />
        </div>
      </div>

      <!-- CONTACTS -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87"/><circle cx="9" cy="7" r="4"/><circle cx="15" cy="7" r="4"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Contactos</span>
            <span x-show="lang==='en'">Contacts</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <FeatureBlock title="Gesti\u00f3n de Contactos" titleEn="Contact Management" bullets={['Importar/exportar JSON y vCard.','Esc\u00e1ner y generador QR.','Sync multi-cuenta (Google, local).','B\u00fasqueda avanzada y filtrado.','Fusi\u00f3n y deduplicaci\u00f3n.']} bulletsEn={['Import/export JSON & vCard.','QR scanner & generator.','Multi-account sync (Google, local).','Advanced search & filtering.','Merge & deduplication.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87"/><circle cx="9" cy="7" r="4"/><circle cx="15" cy="7" r="4"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Automatizaci\u00f3n" titleEn="Automation" bullets={['Sincronizaci\u00f3n autom\u00e1tica multi-cuenta.','Respaldos peri\u00f3dicos de contactos.','Grupos inteligentes y etiquetas.','Compartir lotes por QR.']} bulletsEn={['Automatic multi-account sync.','Periodic contact backups.','Smart groups & labels.','Batch share via QR.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582a8 8 0 111.051 7.637L4 20"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- PRODUCTIVITY -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="4" y="4" width="16" height="16" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8M8 14h6"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Productividad</span>
            <span x-show="lang==='en'">Productivity</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <FeatureBlock title="Suite Completa" titleEn="Full Suite" bullets={['Notas, checklists y voz.','Recordatorios con alarmas.','Grabador de voz integrado.','Bloqueo biom\u00e9trico de notas.']} bulletsEn={['Notes, checklists & voice.','Reminders with alarms.','Built-in voice recorder.','Biometric note locking.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="4" y="4" width="16" height="16" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8M8 14h6"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Dashboard de M\u00e9tricas" titleEn="Metrics Dashboard" bullets={['Estad\u00edsticas de llamadas.','Duraci\u00f3n, tendencias y ratios.','Contactos m\u00e1s frecuentes.','Todo procesado localmente.']} bulletsEn={['Call statistics.','Duration, trends & ratios.','Most frequent contacts.','All processed locally.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M11 3.055A9.001 9.001 0 1020.945 13H11z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- SCREENSHOT BREAK -->
      <div class="flex justify-center py-8">
        <div class="overflow-hidden rounded-2xl border border-neutral-200/60 shadow-xl dark:border-white/10">
          <img src={ssBase + 'tools1.png' + v} alt="Fun Phone tools" class="h-[360px] w-auto object-contain" loading="lazy" />
        </div>
      </div>

      <!-- SECURITY & UTILITIES -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="4" y="10" width="16" height="10" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 10V8a4 4 0 118 0v2"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Seguridad y utilidades</span>
            <span x-show="lang==='en'">Security & utilities</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <FeatureBlock title="Gestor de Contrase\u00f1as" titleEn="Password Manager" bullets={['Cifrado Tink en dispositivo.','Generador de contrase\u00f1as fuertes.','Protecci\u00f3n biom\u00e9trica/PIN.']} bulletsEn={['On-device Tink encryption.','Strong password generator.','Biometric/PIN protection.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="4" y="10" width="16" height="10" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 10V8a4 4 0 118 0v2"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Herramientas de Voz" titleEn="Voice Tools" bullets={['Dictado voz a texto.','TTS multi-idioma.','Compartir como texto o audio.']} bulletsEn={['Speech to text dictation.','Multi-language TTS.','Share as text or audio.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Utilidades QR" titleEn="QR Utilities" bullets={['Esc\u00e1ner y generador QR.','Historial de escaneos.','Compartir contactos por QR.']} bulletsEn={['QR scanner & generator.','Scan history.','Share contacts via QR.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h6v6H3zM15 3h6v6h-6zM3 15h6v6H3zM15 15h2v2h-2zM19 15h2v2h-2zM17 19h2v2h-2z"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- LIFESTYLE -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Estilo de vida y finanzas</span>
            <span x-show="lang==='en'">Lifestyle & finances</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <FeatureBlock title="Gestor de Gastos" titleEn="Expense Manager" bullets={['Ingresos y gastos por categor\u00eda.','Presupuestos mensuales.','Balance y estad\u00edsticas en tiempo real.']} bulletsEn={['Income & expenses by category.','Monthly budgets.','Real-time balance & stats.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Calendario Menstrual" titleEn="Menstrual Calendar" bullets={['Seguimiento con predicciones.','Fases: menstrual, folicular, ovulaci\u00f3n, l\u00fatea.','Datos 100% privados en dispositivo.']} bulletsEn={['Cycle tracking with predictions.','Phases: menstrual, follicular, ovulation, luteal.','100% private on-device data.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M8 2v4M16 2v4M3 10h18"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- ENTERTAINMENT -->
      <section class="py-12">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/></svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 dark:text-white">
            <span x-show="lang==='es'">Entretenimiento</span>
            <span x-show="lang==='en'">Entertainment</span>
          </h2>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          <FeatureBlock title="10 Minijuegos" titleEn="10 Mini-Games" bullets={['Fun Bird, Snake, Buscaminas, 2048.','Puzzle, Tres en raya, Ahorcado.','Breakout, Sudoku, Memory.']} bulletsEn={['Fun Bird, Snake, Minesweeper, 2048.','Puzzle, Tic-Tac-Toe, Hangman.','Breakout, Sudoku, Memory.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Estudio de Pintura" titleEn="Paint Studio" bullets={['Pinceles expresivos.','Importar y exportar obras.','Compartir en galer\u00eda y redes.']} bulletsEn={['Expressive brushes.','Import & export artwork.','Share to gallery & social.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </FeatureBlock>
          <FeatureBlock title="Personalizaci\u00f3n Total" titleEn="Full Customization" bullets={['Temas, colores y fuentes.','Animaciones y transiciones.','Modo claro/oscuro autom\u00e1tico.']} bulletsEn={['Themes, colors & fonts.','Animations & transitions.','Auto light/dark mode.']}>
            <svg slot="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 3.487a2.25 2.25 0 113.182 3.182L7.5 19.213l-4.5 1.5 1.5-4.5 12.362-12.726z"/></svg>
          </FeatureBlock>
        </div>
      </section>

      <!-- COMPARISON TABLE -->
      <section class="py-16">
        <div class="mx-auto mb-12 max-w-2xl text-center">
          <h2 class="font-display text-3xl font-black tracking-tight">
            <span x-show="lang==='es'" class="text-neutral-900 dark:text-white">Fun Phone <span class="text-accent">vs</span> Stock Dialer</span>
            <span x-show="lang==='en'" class="text-neutral-900 dark:text-white">Fun Phone <span class="text-accent">vs</span> Stock Dialer</span>
          </h2>
        </div>
        <div class="mx-auto max-w-4xl">
          <ComparisonTable />
        </div>
      </section>

      <!-- CTA -->
      <section class="rounded-3xl bg-gradient-to-br from-accent/5 via-transparent to-electric/5 p-12 text-center dark:from-accent/10 dark:to-electric/10">
        <h2 class="font-display text-3xl font-black text-neutral-900 dark:text-white">
          <span x-show="lang==='es'">&iquest;Listo para probarlo?</span>
          <span x-show="lang==='en'">Ready to try it?</span>
        </h2>
        <div class="mt-8">
          <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" class="inline-flex items-center gap-3 rounded-2xl bg-accent px-8 py-4 font-display text-base font-bold text-white shadow-xl shadow-accent/25 transition-all hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-accent/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M3 20.5v-17c0-.8.9-1.3 1.6-.8l14.4 8.5c.7.4.7 1.2 0 1.6L4.6 21.3c-.7.5-1.6 0-1.6-.8z"/></svg>
            <span x-show="lang==='es'">Descargar gratis en Google Play</span>
            <span x-show="lang==='en'">Download free on Google Play</span>
          </a>
        </div>
      </section>
    </main>

    <Footer />
    <script is:inline>
      function pageState() {
        return {
          lang: localStorage.getItem('lang') || (navigator.language?.startsWith('es') ? 'es' : 'en'),
          init() { document.documentElement.setAttribute('data-lang', this.lang); },
          updateLang(v) { if (!v) return; this.lang = v; document.documentElement.setAttribute('data-lang', this.lang); }
        };
      }
    </script>
  </body>
</html>
