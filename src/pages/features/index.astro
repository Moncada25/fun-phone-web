---
import Base from '../../layouts/Base.astro';
import FeatureBlock from '../../components/FeatureBlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';

const base = import.meta.env.BASE_URL;
const ssBase = base + 'assets/screenshots/';
const v = '?v=4.0.0';

const groups = [
  {
    chapter: '03',
    title: { es: 'Comunicación', en: 'Communication' },
    blurb: { es: 'Todo lo que necesitas para hablar, llamar y organizar tus conexiones.', en: 'Everything you need to talk, call and organize your connections.' },
    items: [
      { title: { es: 'Marcador Avanzado', en: 'Advanced Dialer' }, bullets: ['Búsqueda T9 inteligente y marcado rápido.', 'Historial con filtros, favoritos y búsqueda.', 'Interfaz pro: retener, silenciar, altavoz.', 'Dual-SIM y enrutamiento inteligente.', 'Marcado por voz y sensor de proximidad.'], variant: 'light' },
      { title: { es: 'Privacidad Primero', en: 'Privacy First' }, bullets: ['Permisos granulares con explicaciones claras.', 'Datos locales, nunca compartidos.', 'Sin anuncios invasivos.', 'Control total sobre acceso y permisos.'], variant: 'dark' },
    ]
  },
  {
    chapter: '04',
    title: { es: 'Contactos', en: 'Contacts' },
    blurb: { es: 'Gestiona tu agenda con herramientas que otros dialers ni imaginan.', en: 'Manage your address book with tools other dialers can\'t even imagine.' },
    items: [
      { title: { es: 'Gestión de Contactos', en: 'Contact Management' }, bullets: ['Importar/exportar JSON y vCard.', 'Escáner y generador QR.', 'Sync multi-cuenta (Google, local).', 'Búsqueda avanzada y filtrado.', 'Fusión y deduplicación.'], variant: 'light' },
      { title: { es: 'Anti-spam', en: 'Anti-spam' }, bullets: ['Bloqueo de números y lista negra.', 'Reportar spam en una pulsación.', 'Filtros inteligentes de llamadas.'], variant: 'flame' },
    ]
  },
  {
    chapter: '05',
    title: { es: 'Productividad', en: 'Productivity' },
    blurb: { es: 'Notas, tareas y recordatorios en un único espacio privado.', en: 'Notes, tasks and reminders in a single private space.' },
    items: [
      { title: { es: 'Suite Completa', en: 'Full Suite' }, bullets: ['Notas, checklists y voz.', 'Recordatorios con alarmas.', 'Grabador de voz integrado.', 'Bloqueo biométrico de notas.'], variant: 'light' },
      { title: { es: 'Dashboard de Métricas', en: 'Metrics Dashboard' }, bullets: ['Estadísticas de llamadas.', 'Duración, tendencias y ratios.', 'Contactos más frecuentes.', 'Todo procesado localmente.'], variant: 'dark' },
    ]
  },
  {
    chapter: '06',
    title: { es: 'Seguridad y utilidades', en: 'Security & utilities' },
    blurb: { es: 'Tus secretos, cifrados en tu dispositivo. Punto.', en: 'Your secrets, encrypted on your device. Period.' },
    items: [
      { title: { es: 'Gestor de Contraseñas', en: 'Password Manager' }, bullets: ['Cifrado Tink en dispositivo.', 'Generador de contraseñas fuertes.', 'Protección biométrica/PIN.'], variant: 'flame' },
      { title: { es: 'Herramientas de Voz', en: 'Voice Tools' }, bullets: ['Dictado voz a texto.', 'TTS multi-idioma.', 'Compartir como texto o audio.'], variant: 'light' },
      { title: { es: 'Utilidades QR', en: 'QR Utilities' }, bullets: ['Escáner y generador QR.', 'Historial de escaneos.', 'Compartir contactos por QR.'], variant: 'dark' },
    ]
  },
  {
    chapter: '07',
    title: { es: 'Estilo de vida y finanzas', en: 'Lifestyle & finances' },
    blurb: { es: 'Bienestar y dinero bajo el mismo techo cifrado.', en: 'Wellness and money under the same encrypted roof.' },
    items: [
      { title: { es: 'Gestor de Gastos', en: 'Expense Manager' }, bullets: ['Ingresos y gastos por categoría.', 'Presupuestos mensuales.', 'Balance y estadísticas en tiempo real.'], variant: 'light' },
      { title: { es: 'Calendario Menstrual', en: 'Menstrual Calendar' }, bullets: ['Seguimiento con predicciones.', 'Fases: menstrual, folicular, ovulación, lútea.', 'Datos 100% privados en dispositivo.'], variant: 'flame' },
    ]
  },
  {
    chapter: '08',
    title: { es: 'Estudio y enfoque', en: 'Study & focus' },
    blurb: { es: 'Para gente que rinde, no para gente que procrastina.', en: 'For people who ship, not for people who procrastinate.' },
    items: [
      { title: { es: 'Gestión Académica', en: 'Academic Management' }, bullets: ['Materias, notas y promedios ponderados.', 'Tareas, asistencia y reportes.', 'Estadísticas de estudio.'], variant: 'flame' },
      { title: { es: 'Pomodoro', en: 'Pomodoro' }, bullets: ['Técnica 25/5 configurable.', 'Sonidos y notificaciones.', 'Funciona en segundo plano.'], variant: 'dark' },
    ]
  },
  {
    chapter: '09',
    title: { es: 'Entretenimiento', en: 'Entertainment' },
    blurb: { es: 'Ríete un rato. Sin micropagos, sin trampas.', en: 'Laugh for a while. No microtransactions, no tricks.' },
    items: [
      { title: { es: '10 Minijuegos', en: '10 Mini-Games' }, bullets: ['Fun Bird, Snake, Buscaminas, 2048.', 'Puzzle, Tres en raya, Ahorcado.', 'Breakout, Sudoku, Memory.'], variant: 'dark' },
      { title: { es: 'Estudio de Pintura', en: 'Paint Studio' }, bullets: ['Pinceles expresivos.', 'Importar y exportar obras.', 'Compartir en galería y redes.'], variant: 'light' },
      { title: { es: 'Personalización Total', en: 'Full Customization' }, bullets: ['Temas, colores y fuentes.', 'Animaciones, transiciones y widgets.', 'Modo claro/oscuro automático.'], variant: 'flame' },
    ]
  },
  {
    chapter: '10',
    title: { es: 'Código abierto', en: 'Open source' },
    blurb: { es: 'Auditable. Modificable. Fiable.', en: 'Auditable. Modifiable. Trustworthy.' },
    items: [
      { title: { es: 'GPL v3', en: 'GPL v3' }, bullets: ['Código disponible en GitHub.', 'Builds FOSS sin Firebase.', 'PRs de la comunidad bienvenidos.'], variant: 'flame' },
    ]
  },
];
---

<Base
  title="Features — Fun Phone"
  description="Explore all Fun Phone features: advanced dialer, smart contacts, productivity suite, password manager, expense tracker, games and more."
  canonical="https://moncada25.github.io/fun-phone-web/features/"
>
  <!-- Hero -->
  <section class="relative border-b border-ink/15">
    <div class="container-editorial py-20 md:py-28">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3 reveal">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo 01</p>
          <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">
            <span x-show="lang==='es'">El índice</span>
            <span x-show="lang==='en'">The index</span>
          </p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h1 class="reveal text-balance font-display-condensed text-[3rem] font-extrabold leading-[0.92] tracking-tightest text-ink sm:text-[4.5rem] md:text-[6rem] lg:text-[7rem]">
            <span x-show="lang==='es'">Funciones que </span>
            <span x-show="lang==='en'">Features that </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">transforman</span>
              <span x-show="lang==='en'">transform</span>
            </span>
            <span x-show="lang==='es'"> tu teléfono</span>
            <span x-show="lang==='en'"> your phone</span>
            <span x-show="lang==='es'"> en algo más.</span>
            <span x-show="lang==='en'"> into something more.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-pretty text-base text-ink-muted md:text-lg">
            <span x-show="lang==='es'">Una taxonomía honesta de lo que hace Fun Phone. Sin funciones fantasma, sin promesas vacías.</span>
            <span x-show="lang==='en'">An honest taxonomy of what Fun Phone actually does. No ghost features, no empty promises.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshot break 01 -->
  <section class="border-b border-ink/15 py-12 md:py-16">
    <div class="container-editorial">
      <div class="grid grid-cols-12 items-end gap-6">
        <div class="col-span-12 md:col-span-5">
          <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">Fig. 02</p>
          <p class="mt-2 font-display-condensed text-3xl font-extrabold leading-tight tracking-tightest text-ink">
            <span x-show="lang==='es'">Favoritos. Sin enredos.</span>
            <span x-show="lang==='en'">Favorites. Without the mess.</span>
          </p>
        </div>
        <div class="col-span-12 md:col-span-7">
          <div class="overflow-hidden border border-ink/15" style="border-radius: 24px;">
            <img src={ssBase + 'favorites.png' + v} alt="Fun Phone contacts" class="block h-auto w-full" loading="lazy" width="540" height="1080" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature groups -->
  {groups.map((group) => (
    <section class="relative border-b border-ink/15 py-16 md:py-24">
      <div class="container-editorial">
        <div class="mb-10 grid grid-cols-12 items-end gap-6">
          <div class="col-span-12 md:col-span-3">
            <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo {group.chapter}</p>
            <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">{group.title.es} / {group.title.en}</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="text-balance font-display-condensed text-[2.25rem] font-extrabold leading-[0.95] tracking-tightest text-ink md:text-[3rem]">
              <span x-show="lang==='es'">{group.title.es}</span>
              <span x-show="lang==='en'">{group.title.en}</span>
            </h2>
            <p class="mt-3 max-w-xl text-pretty text-sm text-ink-muted md:text-base">
              <span x-show="lang==='es'">{group.blurb.es}</span>
              <span x-show="lang==='en'">{group.blurb.en}</span>
            </p>
          </div>
        </div>
        <div class:list={['grid gap-4', group.items.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-3']}>
          {group.items.map((item, idx) => (
            <FeatureBlock
              title={item.title.es}
              titleEn={item.title.en}
              bullets={item.bullets}
              number={(idx + 1).toString().padStart(2, '0')}
              variant={item.variant as any}
              category={{ es: group.title.es, en: group.title.en }}
            >
              <svg slot="icon" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 5l7 7-7 7"/>
              </svg>
            </FeatureBlock>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Screenshot break 02 -->
  <section class="border-b border-ink/15 py-12 md:py-16">
    <div class="container-editorial">
      <div class="grid grid-cols-12 items-end gap-6">
        <div class="col-span-12 md:col-span-7 order-2 md:order-1">
          <div class="overflow-hidden border border-ink/15" style="border-radius: 24px;">
            <img src={ssBase + 'tools1.png' + v} alt="Fun Phone tools" class="block h-auto w-full" loading="lazy" width="540" height="1080" />
          </div>
        </div>
        <div class="col-span-12 md:col-span-5 order-1 md:order-2 md:text-right">
          <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em] text-ink-ghost">Fig. 03</p>
          <p class="mt-2 font-display-condensed text-3xl font-extrabold leading-tight tracking-tightest text-ink">
            <span x-show="lang==='es'">El hub. Quince atajos.</span>
            <span x-show="lang==='en'">The hub. Fifteen shortcuts.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="border-t border-ink/15 py-20 md:py-28">
    <div class="container-editorial">
      <div class="mb-12 grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo 09</p>
          <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">vs. Stock Dialer</p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.96] tracking-tightest text-ink md:text-[4rem]">
            <span x-show="lang==='es'">El marcador de fábrica, </span>
            <span x-show="lang==='en'">The stock dialer, </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">en números.</span>
              <span x-show="lang==='en'">by the numbers.</span>
            </span>
          </h2>
        </div>
      </div>
      <ComparisonTable />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-b border-ink/15 py-20 md:py-28">
    <div class="container-editorial">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">El último capítulo</p>
        <h2 class="mt-6 text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.95] tracking-tightest text-ink md:text-[4rem]">
          <span x-show="lang==='es'">¿Listo para </span>
          <span x-show="lang==='en'">Ready to </span>
          <span class="font-serif-italic text-flame">
            <span x-show="lang==='es'">probarlo</span>
            <span x-show="lang==='en'">try it</span>
          </span>
          <span x-show="lang==='es'">?</span>
          <span x-show="lang==='en'">?</span>
        </h2>
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="https://play.google.com/store/apps/details?id=com.bookverse.contacts" target="_blank" rel="noopener" class="btn-primary group">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893 2.302 2.302-10.937 6.333 8.635-8.635z"/></svg>
            <span x-show="lang==='es'">Instalar gratis</span>
            <span x-show="lang==='en'">Install free</span>
          </a>
          <a href={base + 'faq/'} class="btn-ghost">
            <span x-show="lang==='es'">Preguntas frecuentes</span>
            <span x-show="lang==='en'">Read the FAQ</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
