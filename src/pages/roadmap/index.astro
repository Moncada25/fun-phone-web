---
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://moncada25.github.io/fun-phone-web/roadmap/';
---
<!DOCTYPE html>
<html lang="es" x-data="pageState()" x-on:lang.window="updateLang($event.detail)" x-bind:lang="lang" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Roadmap | Fun Phone: Dialer & Contacts</title>
    <meta name="description" content="Discover what's next for Fun Phone: growth goals, quality improvements, and new features planned." />
    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" href={siteUrl} hreflang="es" />
    <link rel="alternate" href={siteUrl} hreflang="en" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Fun Phone" />
    <meta property="og:title" content="Fun Phone Roadmap" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    <link rel="icon" type="image/png" href={base + 'assets/logo.png'} />
    <link rel="apple-touch-icon" href={base + 'assets/logo.png'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script>
      const prefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
      const saved = localStorage.getItem('darkMode');
      const isDark = saved !== null ? saved === 'true' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
      document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak]{display:none!important}</style>
  </head>
  <body class="font-body bg-white text-neutral-900 antialiased dark:bg-midnight dark:text-neutral-100">
    <Navbar />
    <main id="main-content" class="mx-auto max-w-6xl px-6 pt-28 pb-20">
      <header class="py-16 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent">
          <span x-show="lang==='es'">Visi&oacute;n y camino</span>
          <span x-show="lang==='en'">Vision & path</span>
        </p>
        <h1 class="mt-4 font-display text-4xl font-black tracking-tight sm:text-5xl">
          <span x-show="lang==='es'" class="text-neutral-900 dark:text-white">Roadmap de <span class="text-accent">Fun Phone</span></span>
          <span x-show="lang==='en'" class="text-neutral-900 dark:text-white">Fun Phone <span class="text-accent">Roadmap</span></span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-neutral-500 dark:text-neutral-400" x-show="lang==='es'">
          Crecimiento, nuevas funciones y mejoras manteniendo privacidad real y filosof&iacute;a local-first.
        </p>
        <p class="mx-auto mt-5 max-w-xl text-neutral-500 dark:text-neutral-400" x-show="lang==='en'">
          Growth, new features and improvements while staying local-first and privacy-respecting.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-2">
          <span class="rounded-full border border-neutral-200/60 px-4 py-1.5 text-xs font-semibold text-neutral-500 dark:border-white/10 dark:text-neutral-400">Android 9+</span>
          <span class="rounded-full border border-neutral-200/60 px-4 py-1.5 text-xs font-semibold text-neutral-500 dark:border-white/10 dark:text-neutral-400">Local-first</span>
          <span class="rounded-full border border-neutral-200/60 px-4 py-1.5 text-xs font-semibold text-neutral-500 dark:border-white/10 dark:text-neutral-400">
            <span x-show="lang==='es'">Sin anuncios</span>
            <span x-show="lang==='en'">Ad-free</span>
          </span>
        </div>
      </header>

      <!-- TIMELINE -->
      <div class="relative grid gap-6 md:grid-cols-3">
        <div class="hidden md:block absolute left-0 right-0 top-8 h-0.5 bg-gradient-to-r from-accent via-electric to-accent/30"></div>
        {[
          {
            phase: 'Now',
            color: 'bg-accent',
            items: [
              { es: 'T9 a\u00fan m\u00e1s r\u00e1pido y preciso.', en: 'Even faster and more precise T9.' },
              { es: 'Notas: plantillas y fijar a contacto.', en: 'Notes: templates and pin to contact.' },
              { es: 'Gestor de contrase\u00f1as: UX mejorada.', en: 'Password manager: improved UX.' },
              { es: 'Utilidades QR: historial mejorado.', en: 'QR utilities: improved history.' },
              { es: 'Rendimiento: inicio < 2s.', en: 'Performance: startup < 2s.' },
            ]
          },
          {
            phase: 'Next',
            color: 'bg-electric',
            items: [
              { es: 'Widgets: favoritos, notas, marcaci\u00f3n.', en: 'Widgets: favorites, notes, dialing.' },
              { es: 'Accesibilidad: fuente + alto contraste.', en: 'Accessibility: font size + high contrast.' },
              { es: 'Calendario de festivos ampliado.', en: 'Expanded holiday calendar.' },
              { es: 'Deduplicaci\u00f3n con sugerencias.', en: 'Deduplication with merge suggestions.' },
              { es: 'Juegos: skins y marcadores.', en: 'Games: skins and leaderboards.' },
            ]
          },
          {
            phase: 'Later',
            color: 'bg-accent/40',
            items: [
              { es: 'Anal\u00edticas de llamadas en dispositivo.', en: 'On-device call analytics.' },
              { es: 'M\u00e1s temas, fuentes y animaciones.', en: 'More themes, fonts & animations.' },
              { es: 'Multi-idioma: PT-BR, FR.', en: 'Multi-language: PT-BR, FR.' },
              { es: 'Respuestas r\u00e1pidas post-llamada.', en: 'Quick responses post-call.' },
              { es: 'Backups cifrados.', en: 'Encrypted backups.' },
            ]
          }
        ].map((col) => (
          <div class="relative rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
            <div class="mb-5 flex items-center gap-3">
              <span class:list={['h-3 w-3 rounded-full', col.color]}></span>
              <h2 class="font-display text-lg font-bold text-neutral-900 dark:text-white">{col.phase}</h2>
            </div>
            <ul class="space-y-3 text-sm text-neutral-600 dark:text-neutral-400">
              {col.items.map((item) => (
                <li class="flex items-start gap-2.5">
                  <span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent/60"></span>
                  <span>
                    <span x-show="lang==='es'">{item.es}</span>
                    <span x-show="lang==='en'">{item.en}</span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- STRATEGIC THEMES -->
      <section class="mt-16">
        <h2 class="mb-8 text-center font-display text-2xl font-bold text-neutral-900 dark:text-white">
          <span x-show="lang==='es'">Temas estrat&eacute;gicos</span>
          <span x-show="lang==='en'">Strategic themes</span>
        </h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {[
            { tEs: 'Crecimiento', tEn: 'Growth', items: [{ es: '10k+ instalaciones, 4.6+ rating.', en: '10k+ installs, 4.6+ rating.' }, { es: 'Mejor onboarding.', en: 'Better onboarding.' }, { es: 'M\u00e1s regiones.', en: 'More regions.' }] },
            { tEs: 'Calidad', tEn: 'Quality', items: [{ es: '99.5% sesiones sin fallos.', en: '99.5% crash-free sessions.' }, { es: 'Rendimiento en listas grandes.', en: 'Large list performance.' }, { es: 'Migraciones robustas.', en: 'Robust migrations.' }] },
            { tEs: 'Funcionalidad', tEn: 'Functionality', items: [{ es: 'Contactos avanzados.', en: 'Advanced contacts.' }, { es: 'Suite flexible.', en: 'Flexible suite.' }, { es: 'M\u00e1s juegos y utilidades.', en: 'More games & utilities.' }] },
          ].map((theme) => (
            <div class="rounded-2xl border border-neutral-200/60 bg-white/60 p-6 backdrop-blur dark:border-white/[0.06] dark:bg-white/[0.02]">
              <h3 class="font-display text-base font-bold text-accent">
                <span x-show="lang==='es'">{theme.tEs}</span>
                <span x-show="lang==='en'">{theme.tEn}</span>
              </h3>
              <ul class="mt-3 space-y-2 text-sm text-neutral-600 dark:text-neutral-400">
                {theme.items.map((it) => (
                  <li class="flex items-start gap-2"><span class="mt-1.5 h-1 w-1 flex-shrink-0 rounded-full bg-accent/60"></span><span><span x-show="lang==='es'">{it.es}</span><span x-show="lang==='en'">{it.en}</span></span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- FEEDBACK CTA -->
      <section class="mt-16 rounded-2xl bg-gradient-to-br from-accent/5 to-electric/5 p-10 text-center dark:from-accent/10 dark:to-electric/10">
        <p class="font-display text-lg font-bold text-neutral-900 dark:text-white" x-show="lang==='es'">&iquest;Ideas o prioridades?</p>
        <p class="font-display text-lg font-bold text-neutral-900 dark:text-white" x-show="lang==='en'">Got ideas or priorities?</p>
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
          <a href="mailto:santiago.moncada.dev@gmail.com" class="text-accent hover:underline">santiago.moncada.dev@gmail.com</a>
        </p>
        <a href={base + 'features/'} class="mt-6 inline-flex items-center gap-2 rounded-xl border border-accent/30 px-6 py-3 text-sm font-bold text-accent transition hover:-translate-y-0.5 hover:bg-accent/5">
          <span x-show="lang==='es'">Ver funciones actuales</span>
          <span x-show="lang==='en'">See current features</span>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </section>
    </main>
    <Footer />
    <script is:inline>
      function pageState() {
        return {
          lang: localStorage.getItem('lang') || (navigator.language?.startsWith('es') ? 'es' : 'en'),
          init() { document.documentElement.setAttribute('data-lang', this.lang); },
          updateLang(v) { if (!v) return; this.lang = v; document.documentElement.setAttribute('data-lang', this.lang); }
        };
      }
    </script>
  </body>
</html>
