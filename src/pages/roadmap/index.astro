---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL;

const phases = [
  {
    label: { es: 'Ahora', en: 'Now' },
    accent: 'flame',
    items: [
      { es: 'T9 aún más rápido y preciso.', en: 'Even faster and more precise T9.' },
      { es: 'Notas: plantillas y fijar a contacto.', en: 'Notes: templates and pin to contact.' },
      { es: 'Gestor de contraseñas: UX mejorada.', en: 'Password manager: improved UX.' },
      { es: 'Utilidades QR: historial mejorado.', en: 'QR utilities: improved history.' },
      { es: 'Rendimiento: inicio < 2s.', en: 'Performance: startup under 2s.' },
    ]
  },
  {
    label: { es: 'Luego', en: 'Next' },
    accent: 'ink',
    items: [
      { es: 'Widgets: favoritos, notas, marcación.', en: 'Widgets: favorites, notes, dialing.' },
      { es: 'Accesibilidad: fuente + alto contraste.', en: 'Accessibility: font size + high contrast.' },
      { es: 'Calendario de festivos ampliado.', en: 'Expanded holiday calendar.' },
      { es: 'Deduplicación con sugerencias.', en: 'Deduplication with merge suggestions.' },
      { es: 'Juegos: skins y marcadores.', en: 'Games: skins and leaderboards.' },
    ]
  },
  {
    label: { es: 'Después', en: 'Later' },
    accent: 'ghost',
    items: [
      { es: 'Analíticas de llamadas en dispositivo.', en: 'On-device call analytics.' },
      { es: 'Más temas, fuentes y animaciones.', en: 'More themes, fonts & animations.' },
      { es: 'Multi-idioma: PT-BR, FR.', en: 'Multi-language: PT-BR, FR.' },
      { es: 'Respuestas rápidas post-llamada.', en: 'Quick responses post-call.' },
      { es: 'Backups cifrados.', en: 'Encrypted backups.' },
    ]
  }
];

const themes = [
  { es: 'Crecimiento', en: 'Growth', items: [{ es: '10k+ instalaciones, 4.6+ rating.', en: '10k+ installs, 4.6+ rating.' }, { es: 'Mejor onboarding.', en: 'Better onboarding.' }, { es: 'Más regiones.', en: 'More regions.' }] },
  { es: 'Calidad', en: 'Quality', items: [{ es: '99.5% sesiones sin fallos.', en: '99.5% crash-free sessions.' }, { es: 'Rendimiento en listas grandes.', en: 'Large list performance.' }, { es: 'Migraciones robustas.', en: 'Robust migrations.' }] },
  { es: 'Funcionalidad', en: 'Functionality', items: [{ es: 'Contactos avanzados.', en: 'Advanced contacts.' }, { es: 'Suite flexible.', en: 'Flexible suite.' }, { es: 'Más juegos y utilidades.', en: 'More games & utilities.' }] },
];
---

<Base
  title="Roadmap — Fun Phone"
  description="Discover what's next for Fun Phone: growth goals, quality improvements, and new features planned."
  canonical="https://moncada25.github.io/fun-phone-web/roadmap/"
>
  <!-- Hero -->
  <section class="relative border-b border-ink/15">
    <div class="container-editorial py-20 md:py-28">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3 reveal">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo 01</p>
          <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">
            <span x-show="lang==='es'">Visión y camino</span>
            <span x-show="lang==='en'">Vision & path</span>
          </p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h1 class="reveal text-balance font-display-condensed text-[3rem] font-extrabold leading-[0.92] tracking-tightest text-ink sm:text-[4.5rem] md:text-[6rem] lg:text-[7rem]">
            <span x-show="lang==='es'">Hoja de </span>
            <span x-show="lang==='en'">The </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">ruta</span>
              <span x-show="lang==='en'">roadmap</span>
            </span>
          </h1>
          <p class="mt-6 max-w-2xl text-pretty text-base text-ink-muted md:text-lg">
            <span x-show="lang==='es'">Lo que viene, lo que podría venir, y la dirección general. Crecimiento con cabeza, sin romper lo que ya funciona.</span>
            <span x-show="lang==='en'">What's next, what might be next, and the general direction. Growth with care, without breaking what already works.</span>
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-2">
            <span class="chip">Android 9+</span>
            <span class="chip">Local-first</span>
            <span class="chip chip-solid">
              <span x-show="lang==='es'">Sin anuncios</span>
              <span x-show="lang==='en'">Ad-free</span>
            </span>
            <span class="chip">GPL v3</span>
            <span class="chip">v3.16.1 → v4.0</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="relative border-b border-ink/15 py-16 md:py-24">
    <div class="container-editorial">
      <div class="mb-12 grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo 02</p>
          <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">
            <span x-show="lang==='es'">El tiempo</span>
            <span x-show="lang==='en'">The time</span>
          </p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="text-balance font-display-condensed text-[2.25rem] font-extrabold leading-[0.95] tracking-tightest text-ink md:text-[3rem]">
            <span x-show="lang==='es'">Tres etapas, </span>
            <span x-show="lang==='en'">Three stages, </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">una sola dirección.</span>
              <span x-show="lang==='en'">one direction.</span>
            </span>
          </h2>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {phases.map((phase, idx) => (
          <article class:list={[
            'group relative flex flex-col gap-5 border p-6 md:p-8 transition-all duration-500 hover:-translate-y-1',
            phase.accent === 'flame' && 'border-ink bg-flame text-paper',
            phase.accent === 'ink' && 'border-ink bg-ink text-paper',
            phase.accent === 'ghost' && 'border-ink/15 bg-paper hover:border-ink',
          ]} style="border-radius: 22px;">
            <header class="flex items-baseline justify-between">
              <div class="flex items-baseline gap-2">
                <span class="font-display-condensed text-5xl font-extrabold leading-none tracking-tighter md:text-6xl">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span class:list={['font-mono text-[0.65rem] font-bold uppercase tracking-[0.2em]', phase.accent === 'ghost' ? 'text-ink-ghost' : 'text-paper/60']}>
                  <span x-show="lang==='es'">{phase.label.es}</span>
                  <span x-show="lang==='en'">{phase.label.en}</span>
                </span>
              </div>
              <span class:list={['font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em]', phase.accent === 'ghost' ? 'text-flame' : 'text-flame']}>
                {phase.accent === 'flame' ? '◆ Now' : phase.accent === 'ink' ? '◇ Next' : '○ Later'}
              </span>
            </header>
            <ul class="flex-1 space-y-2.5 text-sm leading-relaxed">
              {phase.items.map((item) => (
                <li class:list={['flex items-start gap-2.5', phase.accent === 'ghost' ? 'text-ink-muted' : 'text-paper/85']}>
                  <span class:list={['mt-2 h-1 w-1 flex-shrink-0 rounded-full', phase.accent === 'ghost' ? 'bg-flame' : 'bg-paper/60']}></span>
                  <span>
                    <span x-show="lang==='es'">{item.es}</span>
                    <span x-show="lang==='en'">{item.en}</span>
                  </span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Strategic themes -->
  <section class="relative py-16 md:py-24">
    <div class="container-editorial">
      <div class="mb-12 grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">Capítulo 03</p>
          <p class="mt-2 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ink-ghost">
            <span x-show="lang==='es'">Los principios</span>
            <span x-show="lang==='en'">The principles</span>
          </p>
        </div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="text-balance font-display-condensed text-[2.25rem] font-extrabold leading-[0.95] tracking-tightest text-ink md:text-[3rem]">
            <span x-show="lang==='es'">Tres principios, </span>
            <span x-show="lang==='en'">Three principles, </span>
            <span class="font-serif-italic text-flame">
              <span x-show="lang==='es'">no negociables.</span>
              <span x-show="lang==='en'">non-negotiable.</span>
            </span>
          </h2>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {themes.map((theme, idx) => (
          <article class="group flex flex-col gap-5 border border-ink/15 bg-paper p-6 transition-all duration-500 hover:-translate-y-1 hover:border-ink md:p-8" style="border-radius: 22px;">
            <header class="flex items-center justify-between">
              <span class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-flame">§ 0{idx + 1}</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-full bg-ink/5 text-ink transition-transform group-hover:rotate-[20deg] group-hover:bg-flame group-hover:text-paper">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </header>
            <h3 class="font-display-condensed text-2xl font-extrabold leading-tight tracking-tightest text-ink">
              <span x-show="lang==='es'">{theme.es}</span>
              <span x-show="lang==='en'">{theme.en}</span>
            </h3>
            <ul class="flex-1 space-y-2 text-sm text-ink-muted">
              {theme.items.map((it) => (
                <li class="flex items-start gap-2.5">
                  <span class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-flame"></span>
                  <span>
                    <span x-show="lang==='es'">{it.es}</span>
                    <span x-show="lang==='en'">{it.en}</span>
                  </span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Feedback -->
  <section class="border-t border-ink/15 bg-flame py-20 text-paper md:py-28">
    <div class="container-editorial">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-7">
          <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-paper/80">Capítulo final</p>
          <h2 class="mt-6 text-balance font-display-condensed text-[2.5rem] font-extrabold leading-[0.96] tracking-tightest md:text-[4rem]">
            <span x-show="lang==='es'">¿Ideas o </span>
            <span x-show="lang==='en'">Got ideas or </span>
            <span class="font-serif-italic">
              <span x-show="lang==='es'">prioridades</span>
              <span x-show="lang==='en'">priorities</span>
            </span>
            <span x-show="lang==='es'">?</span>
            <span x-show="lang==='en'">?</span>
          </h2>
          <p class="mt-6 max-w-lg text-pretty text-base text-paper/85 md:text-lg">
            <span x-show="lang==='es'">Tu feedback define la próxima iteración. Escríbenos y cuéntanos qué necesitas.</span>
            <span x-show="lang==='en'">Your feedback shapes the next iteration. Drop us a line and tell us what you need.</span>
          </p>
          <a href="mailto:santiago.moncada.dev@gmail.com" class="mt-8 inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3.5 text-sm font-bold text-paper transition-transform hover:-translate-y-0.5">
            santiago.moncada.dev@gmail.com
            <span>→</span>
          </a>
        </div>
        <div class="col-span-12 flex flex-col justify-end gap-3 md:col-span-5 md:items-end">
          <a href={base + 'features/'} class="inline-flex items-center gap-2 border-b-2 border-ink pb-1 font-display text-base font-bold text-ink transition-colors hover:text-flame">
            <span x-show="lang==='es'">Ver funciones actuales</span>
            <span x-show="lang==='en'">See current features</span>
            <span>→</span>
          </a>
          <a href={base + 'faq/'} class="inline-flex items-center gap-2 border-b-2 border-ink pb-1 font-display text-base font-bold text-ink transition-colors hover:text-flame">
            FAQ <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
